.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
}

.tab-bar-icon {
  width: 48rpx;
  height: 48rpx;
  margin-top: 8rpx;
}

.tab-bar-text {
  font-size: 20rpx;
  color: #AEAEB2;
  margin-top: 4rpx;
}

.tab-bar-text.active {
  color: #1A1D26;
  font-weight: 600;
}

/* 中间凸起按钮 */
.center-btn {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 104rpx;
  height: 104rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 50%, #1E40AF 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 6rpx 20rpx rgba(37, 99, 235, 0.4),
    0 0 0 8rpx rgba(37, 99, 235, 0.15);
}

.center-btn:active {
  transform: translateX(-50%) scale(0.92);
}

.center-btn-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.center-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}
