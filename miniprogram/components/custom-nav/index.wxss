.nav {
  width: 100%;
  background: #F5F7FA;
}

.nav-content {
  display: flex;
  align-items: center;
  height: 88rpx;
  position: relative;
}

.nav-left {
  position: absolute;
  left: 5rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

/* 范围选择模式下铺满宽度 */
.nav-left.range-mode {
  position: relative;
  left: 0;
  width: 100%;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-date {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #ffffff;
  border-radius: 999rpx;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.03);
}

.nav-date:active {
  transform: scale(0.96);
  background: #f0f0f0;
}

.nav-date-text {
  font-size: 26rpx;
  color: #6B7280;
  margin-right: 8rpx;
  font-weight: 500;
}

.nav-date-arrow {
  width: 0;
  height: 0;
  border-left: 5rpx solid transparent;
  border-right: 5rpx solid transparent;
  border-top: 6rpx solid #9CA3AF;
}

.nav-title {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-title text {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1D26;
  letter-spacing: -0.5rpx;
}

.nav-title.hidden {
  display: none;
}

/* 季度弹窗 */
.quarter-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
}

.quarter-sheet {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #ffffff;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.quarter-sheet.show {
  transform: translateY(0);
}

.quarter-handle {
  width: 48rpx;
  height: 6rpx;
  background: #E5E7EB;
  border-radius: 3rpx;
  margin: 16rpx auto 0;
}

.quarter-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  font-size: 32rpx;
  color: #1A1D26;
  border-bottom: 1rpx solid #F5F5F5;
}

.quarter-item:active {
  background: #F5F7FA;
}

.quarter-item.active {
  font-weight: 600;
  color: #2563EB;
}

.quarter-check {
  color: #2563EB;
  font-size: 32rpx;
  font-weight: 600;
}

/* 时间范围选择器样式 */
.range-picker {
  flex: 1;
  margin: 0;
}

.range-date {
  width: 80%;
  text-align: center;
  justify-content: center;
}

.range-separator {
  font-size: 26rpx;
  color: #6B7280;
  margin: 0 15rpx;
  font-weight: 500;
  flex-shrink: 0;
}
