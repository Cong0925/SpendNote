<view class="nav">
  <view class="nav-content">
    <view class="nav-left {{viewMode !== 'quarter' ? 'range-mode' : ''}}">
      <!-- 日范围 -->
      <block wx:if="{{viewMode === 'day'}}">
        <picker mode="date" value="{{tempStartDate}}" bindchange="onStartDateChange" class="date-picker range-picker">
          <view class="nav-date range-date">
            <text class="nav-date-text">{{rangeStartText || '开始日期'}}</text>
            <view class="nav-date-arrow"></view>
          </view>
        </picker>
        <text class="range-separator">至</text>
        <picker mode="date" value="{{tempEndDate}}" bindchange="onEndDateChange" class="date-picker range-picker">
          <view class="nav-date range-date">
            <text class="nav-date-text">{{rangeEndText || '结束日期'}}</text>
            <view class="nav-date-arrow"></view>
          </view>
        </picker>
      </block>

      <!-- 月范围 -->
      <block wx:if="{{viewMode === 'month'}}">
        <picker mode="date" fields="month" value="{{tempStartDate}}" bindchange="onStartDateChange" class="date-picker range-picker">
          <view class="nav-date range-date">
            <text class="nav-date-text">{{rangeStartText || '开始月份'}}</text>
            <view class="nav-date-arrow"></view>
          </view>
        </picker>
        <text class="range-separator">至</text>
        <picker mode="date" fields="month" value="{{tempEndDate}}" bindchange="onEndDateChange" class="date-picker range-picker">
          <view class="nav-date range-date">
            <text class="nav-date-text">{{rangeEndText || '结束月份'}}</text>
            <view class="nav-date-arrow"></view>
          </view>
        </picker>
      </block>

      <!-- 年范围 -->
      <block wx:if="{{viewMode === 'year'}}">
        <picker mode="date" fields="year" value="{{tempStartDate}}" bindchange="onStartDateChange" class="date-picker range-picker">
          <view class="nav-date range-date">
            <text class="nav-date-text">{{rangeStartText || '开始年份'}}</text>
            <view class="nav-date-arrow"></view>
          </view>
        </picker>
        <text class="range-separator">至</text>
        <picker mode="date" fields="year" value="{{tempEndDate}}" bindchange="onEndDateChange" class="date-picker range-picker">
          <view class="nav-date range-date">
            <text class="nav-date-text">{{rangeEndText || '结束年份'}}</text>
            <view class="nav-date-arrow"></view>
          </view>
        </picker>
      </block>

      <!-- 季度保持原逻辑 -->
      <view class="nav-date quarter-btn" wx:if="{{viewMode === 'quarter'}}" catchtap="showQuarterPicker">
        <text class="nav-date-text">{{dateText}}</text>
        <view class="nav-date-arrow"></view>
      </view>
    </view>
  </view>

  <!-- 季度弹窗 -->
  <view class="quarter-mask" wx:if="{{showQuarter}}" bindtap="hideQuarterPicker"></view>
  <view class="quarter-sheet {{showQuarter ? 'show' : ''}}">
    <view class="quarter-handle"></view>
    <view class="quarter-item {{quarterIndex === item.value ? 'active' : ''}}" wx:for="{{quarters}}" wx:key="value" bindtap="selectQuarter" data-value="{{item.value}}">
      <text>{{item.label}}</text>
      <view class="quarter-check" wx:if="{{quarterIndex === item.value}}">✓</view>
    </view>
  </view>
</view>
