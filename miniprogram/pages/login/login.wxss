/* pages/login/login.wxss */

/* ==================== 页面基础 ==================== */
.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #f8faf9 0%, #e8f5e9 50%, #f0f7f0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  position: relative;
  overflow: hidden;
}

/* ==================== 背景装饰 ==================== */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  opacity: 0.4;
}

.orb-1 {
  width: 500rpx;
  height: 500rpx;
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.3) 0%, rgba(6, 173, 86, 0.1) 100%);
  top: -150rpx;
  right: -100rpx;
  animation: float 8s ease-in-out infinite;
}

.orb-2 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.2) 0%, rgba(82, 196, 138, 0.1) 100%);
  bottom: -100rpx;
  left: -80rpx;
  animation: float 10s ease-in-out infinite reverse;
}

.orb-3 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, rgba(114, 204, 158, 0.25) 0%, rgba(7, 193, 96, 0.15) 100%);
  top: 40%;
  left: 60%;
  animation: float 12s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translate(0, 0) scale(1);
  }
  33% {
    transform: translate(20rpx, -30rpx) scale(1.05);
  }
  66% {
    transform: translate(-15rpx, 20rpx) scale(0.95);
  }
}

/* ==================== 主内容区 ==================== */
.content-wrapper {
  width: 100%;
  max-width: 640rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 40rpx;
  padding: 80rpx 50rpx 60rpx;
  box-shadow:
    0 4rpx 8rpx rgba(0, 0, 0, 0.02),
    0 12rpx 24rpx rgba(0, 0, 0, 0.04),
    0 24rpx 48rpx rgba(0, 0, 0, 0.06);
  backdrop-filter: blur(20px);
  position: relative;
  z-index: 1;
}

/* ==================== 品牌标识 ==================== */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.brand-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1d26;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.brand-slogan {
  font-size: 26rpx;
  color: #8c8c8c;
  letter-spacing: 1rpx;
}

/* ==================== 头像区域 ==================== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 56rpx;
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-container {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: visible;
  margin: 0 auto;
}

.avatar-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.avatar-btn:active .avatar-img {
  transform: scale(0.95);
}

.avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.avatar-btn:active .avatar-overlay {
  opacity: 1;
}

.camera-icon {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-icon .icon-text {
  font-size: 32rpx;
}

.avatar-badge {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  padding: 0rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.badge-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
  white-space: nowrap;
}

/* ==================== 昵称输入区 ==================== */
.input-section {
  margin-bottom: 48rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f7f8fa;
  border-radius: 20rpx;
  padding: 0 32rpx;
  height: 112rpx;
  border: 3rpx solid transparent;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.input-wrapper:focus-within {
  background: #fff;
  border-color: #07c160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.1);
}

.input-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  opacity: 0.5;
  transition: opacity 0.3s ease;
}

.input-wrapper:focus-within .input-icon {
  opacity: 1;
}

.input-icon .icon-text {
  font-size: 36rpx;
}

.nickname-input {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  color: #1a1d26;
  font-weight: 500;
}

.placeholder-style {
  color: #bfbfbf;
  font-weight: 400;
}

.input-clear {
  width: 40rpx;
  height: 40rpx;
  background: #e8e8e8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  transition: all 0.2s ease;
}

.input-clear:active {
  background: #d9d9d9;
  transform: scale(0.9);
}

.input-clear .icon-text {
  font-size: 20rpx;
  color: #8c8c8c;
}

/* ==================== 登录按钮 ==================== */
.button-section {
  margin-bottom: 48rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(145deg, #07c160 0%, #06ad56 100%);
  color: white;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.login-btn::after {
  border: none;
}

.login-btn:active:not(.disabled) {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.4);
}

.login-btn.disabled {
  background: linear-gradient(145deg, #e8e8e8 0%, #d9d9d9 100%);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.btn-text {
  position: relative;
  z-index: 1;
}

/* 加载动画 */
.btn-loading {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* ==================== 勾选协议 ==================== */
.agreement-section {
  padding: 0;
}

/* 使用 flex 布局确保对齐 */
.checkbox-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-wrap: nowrap;
}

/* 自定义 checkbox */
.checkbox {
  width: 28rpx;
  height: 28rpx;
  min-width: 28rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 10rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.checkbox.checked {
  background: #07c160;
  border-color: #07c160;
  animation: checkBounce 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes checkBounce {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.15);
  }
  100% {
    transform: scale(1);
  }
}

.check-mark {
  width: 10rpx;
  height: 6rpx;
  border-left: 2rpx solid #fff;
  border-bottom: 2rpx solid #fff;
  transform: rotate(-45deg) translateY(-1rpx);
}

/* 文字样式 - 关键：line-height 与 checkbox 高度一致 */
.agreement-text {
  font-size: 24rpx;
  color: #999;
  line-height: 28rpx;  /* 与 checkbox 高度一致 */
  vertical-align: middle;
}

.link-text {
  font-size: 24rpx;
  color: #07c160;
  font-weight: 500;
  line-height: 28rpx;  /* 与 checkbox 高度一致 */
  vertical-align: middle;
}

.link-text:active {
  opacity: 0.7;
}
