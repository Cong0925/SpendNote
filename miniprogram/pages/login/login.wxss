/* pages/login/login.wxss */

/* ==================== 页面基础 ==================== */
.login-page {
  min-height: 100vh;
  background: var(--color-bg, #F5F7FA);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
}

/* ==================== 极简背景 ==================== */
.minimal-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.bg-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    linear-gradient(180deg, #ffffff 0%, #F5F7FA 30%, #EBF2FF 100%);
}

/* 装饰线条 */
.decor-line {
  position: absolute;
  background: linear-gradient(180deg, transparent, rgba(37, 99, 235, 0.06), transparent);
}

.line-1 {
  width: 1rpx;
  height: 300rpx;
  top: 10%;
  left: 20%;
  animation: floatLine 6s ease-in-out infinite;
}

.line-2 {
  width: 1rpx;
  height: 400rpx;
  top: 30%;
  right: 15%;
  animation: floatLine 8s ease-in-out infinite reverse;
}

.line-3 {
  width: 200rpx;
  height: 1rpx;
  bottom: 20%;
  left: 10%;
  background: linear-gradient(90deg, transparent, rgba(37, 99, 235, 0.06), transparent);
  animation: floatLine 7s ease-in-out infinite;
}

@keyframes floatLine {
  0%, 100% { opacity: 0.5; transform: translateY(0); }
  50% { opacity: 1; transform: translateY(20rpx); }
}

/* ==================== 主内容区 ==================== */
.content-area {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
  padding: 0 48rpx;
}

.top-space {
  height: 180rpx;
}

.bottom-space {
  height: 120rpx;
}

/* ==================== 品牌区域 ==================== */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  animation: fadeIn 1s ease-out;
}

.brand-mark {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.mark-line {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--color-primary, #2563EB));
}

.mark-right {
  background: linear-gradient(90deg, var(--color-primary, #2563EB), transparent);
}

.mark-text {
  font-size: 48rpx;
  font-weight: 200;
  color: var(--color-primary, #2563EB);
  letter-spacing: 4rpx;
  font-family: 'Georgia', serif;
}

.brand-name {
  font-size: 36rpx;
  font-weight: 300;
  color: var(--color-text, #1A1D26);
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
  text-transform: uppercase;
}

.brand-slogan {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
  letter-spacing: 2rpx;
  font-weight: 300;
}

/* ==================== 表单卡片 ==================== */
.form-card {
  width: 100%;
  background: var(--color-card, #FFFFFF);
  border-radius: var(--radius-xl, 32rpx);
  padding: 64rpx 48rpx;
  box-shadow: var(--shadow-lg, 0 8rpx 24rpx rgba(0, 0, 0, 0.08));
  animation: slideUp 0.8s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ==================== 头像区域 ==================== */
.avatar-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 56rpx;
}

.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn::after {
  border: none;
}

.avatar-wrapper {
  margin-bottom: 16rpx;
}

.avatar-border {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: linear-gradient(135deg, var(--color-primary, #2563EB) 0%, var(--color-primary-dark, #1D4ED8) 100%);
  transition: all 0.4s ease;
}

.avatar-btn:active .avatar-border {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.4);
}

.avatar-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--color-bg, #F5F7FA);
  overflow: hidden;
  position: relative;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-hover {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(37, 99, 235, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.avatar-btn:active .avatar-hover {
  opacity: 1;
}

.hover-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

.avatar-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary, #9CA3AF);
  letter-spacing: 1rpx;
}

/* ==================== 输入区域 ==================== */
.input-area {
  margin-bottom: 48rpx;
}

.input-label {
  font-size: 22rpx;
  color: var(--color-text-secondary, #6B7280);
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input-container {
  display: flex;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border, #F0F2F5);
  transition: border-color 0.3s ease;
}

.input-container:focus-within {
  border-color: var(--color-primary, #2563EB);
}

.nickname-input {
  flex: 1;
  height: 80rpx;
  font-size: 32rpx;
  color: var(--color-text, #1A1D26);
  font-weight: 400;
  letter-spacing: 1rpx;
}

.placeholder-style {
  color: var(--color-text-light, #D1D5DB);
  font-weight: 300;
}

.input-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  transition: all 0.2s ease;
}

.input-clear:active {
  transform: scale(0.9);
}

.clear-icon {
  font-size: 32rpx;
  color: var(--color-text-tertiary, #9CA3AF);
  line-height: 1;
}

.input-line {
  height: 2rpx;
  background: var(--color-border, #F0F2F5);
  margin-top: -1rpx;
  overflow: hidden;
}

.line-progress {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary, #2563EB), var(--color-primary-light, #3B82F6));
  animation: lineGrow 0.3s ease-out;
}

@keyframes lineGrow {
  from { width: 0; }
  to { width: 100%; }
}

/* ==================== 登录按钮 ==================== */
.button-area {
  margin-bottom: 48rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, var(--color-primary, #2563EB) 0%, var(--color-primary-dark, #1D4ED8) 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: var(--radius-xl, 32rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 8rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

.login-btn::after {
  border: none;
}

.btn-text {
  position: relative;
  z-index: 1;
}

.btn-hover {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--color-primary-light, #3B82F6) 0%, var(--color-primary-dark, #1D4ED8) 100%);
  opacity: 0;
  transition: opacity 0.4s ease;
}

.login-btn:active:not(.disabled) .btn-hover {
  opacity: 1;
}

.login-btn:active:not(.disabled) {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.4);
}

.login-btn.disabled {
  background: linear-gradient(135deg, var(--color-text-light, #D1D5DB) 0%, var(--color-text-tertiary, #9CA3AF) 100%);
  box-shadow: none;
}

/* ==================== 协议 ==================== */
.agreement-area {
  padding: 0;
}

.checkbox-wrapper {
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.checkbox {
  width: 28rpx;
  height: 28rpx;
  min-width: 28rpx;
  border: 2rpx solid var(--color-text-light, #D1D5DB);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 12rpx;
  margin-top: 4rpx;
  transition: all 0.3s ease;
}

.checkbox.checked {
  background: var(--color-primary, #2563EB);
  border-color: var(--color-primary, #2563EB);
}

.check-mark {
  width: 10rpx;
  height: 6rpx;
  border-left: 2rpx solid #fff;
  border-bottom: 2rpx solid #fff;
  transform: rotate(-45deg) translateY(-1rpx);
}

.agreement-content {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}

.agreement-text {
  font-size: 22rpx;
  color: var(--color-text-tertiary, #9CA3AF);
  line-height: 36rpx;
}

.link {
  font-size: 22rpx;
  color: var(--color-primary, #2563EB);
  font-weight: 500;
  line-height: 36rpx;
}

.link:active {
  opacity: 0.6;
}

/* ==================== 加载状态 ==================== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  animation: fadeIn 0.3s ease;
}

.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--color-primary, #2563EB);
  border-radius: 50%;
  animation: dotPulse 1.4s ease-in-out infinite;
}

.dot-1 { animation-delay: 0s; }
.dot-2 { animation-delay: 0.2s; }
.dot-3 { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #6B7280);
  letter-spacing: 4rpx;
  font-weight: 300;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}