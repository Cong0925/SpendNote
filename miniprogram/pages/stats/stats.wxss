/* pages/stats/stats.wxss - Premium Stats Page */
page {
  background: var(--color-bg);
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.scroll-area {
  flex: 1;
  overflow: hidden;
  box-sizing: border-box;
  padding-bottom: 100rpx;
}

/* ============ 日期选择器 ============ */
.date-selector {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: var(--color-card);
  border-radius: 999rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
  margin-top: 20rpx;
}

.date-selector:active {
  transform: scale(0.96);
  background: var(--color-bg);
}

.date-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-right: 8rpx;
  font-weight: 500;
  white-space: nowrap;
}

.date-arrow {
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 7rpx solid var(--color-text-tertiary);
  flex-shrink: 0;
}

/* ============ 快捷标签 ============ */
.quick-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.quick-tab {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-card);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  transition: all 0.25s ease;
  box-shadow: var(--shadow-sm);
}

.quick-tab:active {
  transform: scale(0.96);
}

.quick-tab.active {
  background: linear-gradient(135deg, #2563EB 0%, #1E40AF 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
}

/* ============ 收支概览卡片 ============ */
.hero-card {
  background: linear-gradient(135deg, #2563EB 0%, #1E40AF 50%, #1E3A8A 100%);
  border-radius: var(--radius-xl);
  padding: 40rpx;
  margin-bottom: 30rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.3);
}

.hero-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.hero-card::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: 30%;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.hero-amounts {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
  width: 100%;
  overflow: hidden;
}

.hero-amount-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow: hidden;
}

.hero-amount-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
  margin-bottom: 10rpx;
  font-weight: 400;
}

.hero-amount-unit {
  margin-left: 20rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.hero-amount-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -1.5rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-amount-value.expense {
  color: #FCA5A5;
}

.hero-amount-value.income {
  color: #86EFAC;
}

.hero-divider {
  width: 1rpx;
  height: 68rpx;
  background: rgba(255, 255, 255, 0.2);
  margin: 0 24rpx;
}

/* ============ 展开状态样式 ============ */
.hero-card.expanded {
  padding-bottom: 24rpx;
}

.hero-amounts-expanded {
  position: relative;
  z-index: 1;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 上方：未点击的两个 */
.hero-amounts-top {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  width: 100%;
  overflow: hidden;
}

/* 上方每个项：flex 等分 + 右侧伪元素分隔线 */
.hero-amounts-top .hero-amount-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow: hidden;
  position: relative;
}

.hero-amounts-top .hero-amount-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 68rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 下方：点击展开的完整金额 */
.hero-amounts-bottom {
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-amount-expanded-item {
  display: flex;
  flex-direction: column;
}

.hero-amount-label-expanded {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.hero-amount-value-expanded {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -2rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
  word-break: break-all;
}

.hero-amount-value-expanded.expense {
  color: #FCA5A5;
}

.hero-amount-value-expanded.income {
  color: #86EFAC;
}

/* ============ Tab栏 ============ */
.tab-section {
  margin-bottom: 24rpx;
}

.tab-bar {
  display: flex;
  background: var(--color-card);
  border-radius: var(--radius-full);
  padding: 6rpx;
  box-shadow: var(--shadow-sm);
}

.tab-item {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-radius: var(--radius-full);
  font-weight: 500;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #2563EB 0%, #1E40AF 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
  font-weight: 600;
}

/* ============ 图表区 ============ */
.chart-section {
  margin-bottom: 32rpx;
}

.donut-wrapper {
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-xl);
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.donut-chart {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  flex-shrink: 0;
  margin-right: 32rpx;
}

.donut-ring {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
}

.donut-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  background: var(--color-card);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.donut-center-amount {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: -0.5rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.donut-center-label {
  font-size: 18rpx;
  color: var(--color-text-tertiary);
  margin-top: 2rpx;
}

.donut-legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.legend-name {
  flex: 1;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.legend-percent {
  font-size: 24rpx;
  color: var(--color-text);
  font-weight: 600;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

/* ============ 统计列表 ============ */
.stats-list {
  background: var(--color-card);
  border-radius: var(--radius-xl);
  padding: 28rpx 32rpx;
  box-shadow: var(--shadow-card);
}

.stats-list-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.stats-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-divider);
}

.stats-item:active {
  background: var(--color-bg);
  border-radius: var(--radius-md);
}

.stats-item:last-child {
  border-bottom: none;
}

.stats-rank {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.stats-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.stats-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.stats-icon {
  font-size: 32rpx;
}

.stats-info {
  flex: 1;
  min-width: 0;
}

.stats-name {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.stats-bar {
  height: 8rpx;
  background: var(--color-bg);
  border-radius: 4rpx;
  overflow: hidden;
}

.stats-bar-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.stats-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.stats-amount {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
  margin-bottom: 4rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.stats-count {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* ============ 空状态 ============ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  background: var(--color-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.empty-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

/* ============ 加载 ============ */
.loading {
  text-align: center;
  padding: 48rpx;
  color: var(--color-text-tertiary);
  font-size: 26rpx;
}

/* ============ 导航栏 ============ */
.nav-bar {
  display: flex;
  align-items: center;
  height: calc(88rpx + env(safe-area-inset-top));
  padding-top: env(safe-area-inset-top);
  padding-left: 20rpx;
  padding-right: 20rpx;
  background: #F5F7FA;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-left {
  position: relative;
}

.nav-date {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: #ffffff;
  border-radius: 999rpx;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.03);
}

.nav-date:active {
  transform: scale(0.96);
  background: #f0f0f0;
}

.nav-date-text {
  font-size: 26rpx;
  color: #6B7280;
  margin-right: 8rpx;
  font-weight: 500;
  white-space: nowrap;
}

.nav-date-arrow {
  width: 0;
  height: 0;
  border-left: 5rpx solid transparent;
  border-right: 5rpx solid transparent;
  border-top: 6rpx solid #9CA3AF;
  flex-shrink: 0;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1D26;
}

/* ============ 季度弹窗 ============ */
.quarter-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
}

.quarter-sheet {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #ffffff;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.quarter-sheet.show {
  transform: translateY(0);
}

.quarter-handle {
  width: 48rpx;
  height: 6rpx;
  background: #E5E7EB;
  border-radius: 3rpx;
  margin: 16rpx auto 0;
}

.quarter-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  font-size: 32rpx;
  color: #1A1D26;
  border-bottom: 1rpx solid #F5F5F5;
}

.quarter-item:active {
  background: #F5F7FA;
}

.quarter-item.active {
  font-weight: 600;
  color: #2563EB;
}

/* ============ 时间范围选择器 ============ */
.range-picker {
  margin-right: 10rpx;
}

.range-date {
  min-width: 120rpx;
  text-align: center;
}

.range-date.active {
  background: #EBF5FF;
  border: 1rpx solid #2563EB;
}

.range-date.active .date-text {
  color: #2563EB;
  font-weight: 600;
}

.range-separator {
  font-size: 26rpx;
  color: #6B7280;
  margin: 0 10rpx;
  font-weight: 500;
}

.quarter-check {
  color: #2563EB;
  font-size: 32rpx;
  font-weight: 600;
}

/* ============ 月度趋势柱状图 ============ */
.trend-section {
  margin-bottom: 32rpx;
}

.trend-card {
  background: var(--color-card);
  border-radius: var(--radius-xl);
  padding: 28rpx 32rpx;
  box-shadow: var(--shadow-card);
}

.trend-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.trend-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.trend-legend {
  display: flex;
  gap: 20rpx;
}

.trend-legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.trend-legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
}

.trend-legend-dot.expense { background: var(--color-expense); }
.trend-legend-dot.income { background: var(--color-income); }

.bar-chart {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 240rpx;
  padding-bottom: 40rpx;
  position: relative;
}

.bar-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  position: relative;
}

.bars {
  flex: 1;
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  width: 100%;
}

.bar {
  flex: 1;
  border-radius: 4rpx 4rpx 0 0;
  min-height: 4rpx;
  transition: height 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.bar.expense-bar {
  background: var(--color-expense);
  opacity: 0.85;
}

.bar.income-bar {
  background: var(--color-income);
  opacity: 0.85;
}

.bar-label {
  position: absolute;
  bottom: 0;
  font-size: 18rpx;
  color: var(--color-text-tertiary);
  white-space: nowrap;
}

/* ============ 分类箭头 ============ */
.stats-arrow {
  margin-left: 8rpx;
  flex-shrink: 0;
}

.arrow-icon {
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid var(--color-text-tertiary);
  border-bottom: 3rpx solid var(--color-text-tertiary);
  transform: rotate(-45deg);
  opacity: 0.5;
}
