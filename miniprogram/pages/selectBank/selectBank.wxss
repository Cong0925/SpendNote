/**
 * 选择银行页面样式（优化版）
 * 柔和渐变 + 毛玻璃效果，现代感设计
 */
page {
  background: linear-gradient(180deg, #e8f4f8 0%, #f0f4f8 30%, #f8fafc 100%);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

/* ============ 装饰性背景元素 ============ */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: -1;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.5;
}

.bg-circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.08) 0%, rgba(147, 197, 253, 0.12) 100%);
  top: -100rpx;
  right: -80rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, rgba(147, 197, 253, 0.1) 0%, rgba(191, 219, 254, 0.15) 100%);
  top: 200rpx;
  left: -60rpx;
}

.bg-circle-3 {
  width: 250rpx;
  height: 250rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.06) 0%, rgba(147, 197, 253, 0.1) 100%);
  bottom: 100rpx;
  right: -40rpx;
}

/* ============ 搜索区域 ============ */
.search-section {
  padding: 24rpx 0;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.8);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 40rpx;
  padding: 24rpx 28rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.search-input-wrap:focus-within {
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 24rpx rgba(59, 130, 246, 0.15);
  transform: scale(1.01);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #94a3b8;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #334155;
}

.clear-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(148, 163, 184, 0.2);
  border-radius: 50%;
  margin-left: 12rpx;
  transition: all 0.2s ease;
}

.clear-btn:active {
  transform: scale(0.9);
  background: rgba(148, 163, 184, 0.3);
}

.clear-btn text {
  font-size: 28rpx;
  color: #64748b;
}

/* ============ 搜索结果 ============ */
.search-results {
  flex: 1;
  padding: 24rpx 32rpx;
}

.result-header {
  margin-bottom: 20rpx;
}

.result-count {
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 500;
}

.result-list {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
}

.result-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.6);
  transition: all 0.2s ease;
}

.result-item:last-child {
  border-bottom: none;
}

.result-item:active {
  background: rgba(59, 130, 246, 0.05);
  transform: scale(0.98);
}

.result-icon {
  width: 72rpx;
  height: 72rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.result-info {
  flex: 1;
  min-width: 0;
}

.result-name {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
}

.result-arrow {
  font-size: 36rpx;
  color: #cbd5e1;
  flex-shrink: 0;
}

/* ============ 内容滚动区 ============ */
.content-scroll {
  flex: 1;
  margin-top:20rpx
}

/* ============ 区块 ============ */
.section {
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  animation: slideUp 0.5s ease-out both;
}

.section:nth-child(1) {
  animation-delay: 0s;
}

.section:nth-child(2) {
  animation-delay: 0.08s;
}

.section:nth-child(3) {
  animation-delay: 0.16s;
}

.section:nth-child(4) {
  animation-delay: 0.24s;
}

.section:nth-child(5) {
  animation-delay: 0.32s;
}

.section:nth-child(6) {
  animation-delay: 0.4s;
}

.section:nth-child(7) {
  animation-delay: 0.48s;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  transition: all 0.2s ease;
  background: rgba(255, 255, 255, 0.4);
}

.section-header:active {
  background: rgba(59, 130, 246, 0.05);
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon {
  font-size: 36rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.section-count {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 400;
}

.expand-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(148, 163, 184, 0.15);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.arrow-icon {
  width: 28rpx;
  height: 28rpx;
}

.expand-arrow.expanded {
  background: rgba(59, 130, 246, 0.15);
}

/* ============ 分类列表 ============ */
.category-list {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.category-list.expanded {
  max-height: 3000rpx;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx 24rpx 80rpx;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.4);
  transition: all 0.2s ease;
}

.category-item:last-child {
  border-bottom: none;
}

.category-item:active {
  background: rgba(59, 130, 246, 0.05);
  transform: scale(0.98);
}

.category-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.category-info {
  flex: 1;
  min-width: 0;
}

.category-name {
  font-size: 28rpx;
  color: #334155;
  font-weight: 500;
}

.category-arrow {
  font-size: 32rpx;
  color: #cbd5e1;
  flex-shrink: 0;
}

/* ============ 热门银行网格 ============ */
.hot-banks-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 16rpx 28rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.03) 0%, rgba(147, 197, 253, 0.06) 100%);
}

.hot-bank-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  transition: all 0.2s ease;
}

.hot-bank-item:active {
  transform: scale(0.9);
}

.hot-bank-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.hot-bank-item:active .hot-bank-icon-wrap {
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.15);
  transform: translateY(-4rpx);
}

.hot-bank-icon {
  width: 68rpx;
  height: 68rpx;
}

.hot-bank-name {
  font-size: 22rpx;
  color: #475569;
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

/* ============ 展开更多按钮 ============ */
.show-more-btn {
  padding: 24rpx 32rpx;
  text-align: center;
  background: rgba(59, 130, 246, 0.04);
  border-top: 1rpx solid rgba(226, 232, 240, 0.4);
  transition: all 0.2s ease;
}

.show-more-btn:active {
  background: rgba(59, 130, 246, 0.08);
}

.show-more-btn text {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 500;
}

/* ============ 空状态 ============ */
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  display: block;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* ============ 底部安全区 ============ */
.safe-bottom {
  height: 48rpx;
}

/* ============ 加载状态 ============ */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(248, 250, 252, 0.9);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid rgba(59, 130, 246, 0.2);
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* ============ 动画效果 ============ */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(32rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ============ 骨架屏样式 ============ */
.hot-bank-item.skeleton {
  pointer-events: none;
}

.hot-bank-item.skeleton .hot-bank-icon-wrap {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

.hot-bank-item.skeleton .skeleton-text {
  width: 60rpx;
  height: 22rpx;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  margin-top: 12rpx;
}

.category-skeleton {
  padding: 24rpx 0;
}

.category-skeleton-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.4);
}

.category-skeleton-item:last-child {
  border-bottom: none;
}

.skeleton-icon-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.category-skeleton-info {
  flex: 1;
}

.category-skeleton-info .skeleton-text {
  border-radius: 8rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

.category-skeleton-info .skeleton-name {
  width: 160rpx;
  height: 28rpx;
  margin-bottom: 8rpx;
}

.category-skeleton-info .skeleton-count {
  width: 100rpx;
  height: 22rpx;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}
