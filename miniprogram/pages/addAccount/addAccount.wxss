/**
 * 添加账户页面样式 - 与现有页面统一
 */
page {
  background: var(--color-bg);
}

.container {
  min-height: 100vh;
}

/* ============ 顶部标题 ============ */
.header {
  padding: 32rpx;
  padding-bottom: 20rpx;
}

.header-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 1.5rpx;
}

/* ============ 区块 ============ */
.section {
  background: var(--color-card);
  border-radius: var(--radius-xl);
  margin-bottom:30rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  animation: slideUp 0.5s ease-out both;
}

.section:nth-child(2) {
  animation-delay: 0.1s;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 1.5rpx;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

/* ============ 账户类型网格 ============ */
.account-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
}

.account-type-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  transition: all 0.2s ease;
  border-radius: var(--radius-md);
}

.account-type-item:active {
  background: var(--color-bg);
  transform: scale(0.95);
}

.type-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 16rpx;
}

.type-name {
  font-size: 24rpx;
  color: var(--color-text);
  text-align: center;
  font-weight: 500;
}

.account-type-item.debt .type-name {
  color: var(--color-expense);
}

/* ============ 提示文字 ============ */
.tip {
  padding: 32rpx;
}

.tip-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.6;
}

/* ============ 动画效果 ============ */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(32rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
