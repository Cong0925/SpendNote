/* pages/yearly-summary/yearly-summary.wxss */

.summary-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1e3a5f 0%, #2563eb 50%, #f5f7fa 100%);
}

/* 内容滚动区 */
.content-scroll {
  height: 100vh;
}

.content-wrapper {
  padding: 32rpx;
  padding-top: 40rpx;
}

/* 统计卡片 */
.stats-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
}

.stat-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.stat-item:last-child {
  border-bottom: none;
}

.stat-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 28rpx;
}

.stat-item.income .stat-icon {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
}

.stat-item.expense .stat-icon {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
}

.stat-item.total .stat-icon {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.stat-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.stat-item.income .stat-value {
  color: #10b981;
}

.stat-item.expense .stat-value {
  color: #ef4444;
}

/* 信息卡片 */
.info-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.info-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.info-divider {
  width: 2rpx;
  height: 80rpx;
  background: #e8e8e8;
}

/* 鼓励卡片 */
.encourage-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
}

.encourage-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
}

.encourage-text {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
}

/* ========== 骨架屏样式 ========== */

/* 骨架屏卡片容器 */
.skeleton-card {
  margin-bottom: 24rpx;
}

/* 骨架屏图标 */
.skeleton-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  margin-right: 28rpx;
}

/* 骨架屏圆形图标 */
.skeleton-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  margin-bottom: 16rpx;
}

/* 骨架屏大圆形（鼓励卡片） */
.skeleton-circle-large {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  margin-bottom: 24rpx;
}

/* 骨架屏文本 */
.skeleton-text {
  height: 28rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  margin-bottom: 12rpx;
}

/* 小文本骨架（标签） */
.skeleton-text-small {
  width: 120rpx;
  height: 24rpx;
}

/* 中等文本骨架（数值） */
.skeleton-text-medium {
  width: 180rpx;
  height: 32rpx;
}

/* 长文本骨架（鼓励语） */
.skeleton-text-long {
  width: 400rpx;
  height: 28rpx;
}

/* 骨架屏加载动画 */
@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}
