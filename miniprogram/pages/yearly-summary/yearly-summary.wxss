/* pages/yearly-summary/yearly-summary.wxss */

.summary-page {
  min-height: 100vh;
  background: var(--color-bg, #F5F7FA);
}

/* 内容滚动区 */
.content-scroll {
  height: 100vh;
}

.content-wrapper {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* 年度标题 */
.year-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 24rpx;
}

.year-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text, #1A1D26);
  margin-bottom: 8rpx;
}

.year-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6B7280);
}

/* 卡片通用样式 */
.overview-card,
.analysis-card,
.usage-card,
.rank-card,
.encourage-card {
  background: var(--color-card, #FFFFFF);
  border-radius: var(--radius-xl, 32rpx);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card, 0 2rpx 8rpx rgba(0, 0, 0, 0.04));
}

.card-header {
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text, #1A1D26);
}

/* 年度总览 */
.overview-stats {
  display: flex;
  justify-content: space-between;
}

.stat-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: var(--radius-lg, 24rpx);
}

.stat-block.income {
  background: var(--color-income-light, #DCFCE7);
}

.stat-block.expense {
  background: var(--color-expense-light, #FEE2E2);
}

.stat-block.total {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary, #6B7280);
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text, #1A1D26);
}

.stat-block.income .stat-value {
  color: var(--color-income, #22C55E);
}

.stat-block.expense .stat-value {
  color: var(--color-expense, #EF4444);
}

/* 消费分析 */
.analysis-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.analysis-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--color-bg, #F5F7FA);
  border-radius: var(--radius-lg, 24rpx);
}

.analysis-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.analysis-content {
  display: flex;
  flex-direction: column;
}

.analysis-label {
  font-size: 20rpx;
  color: var(--color-text-secondary, #6B7280);
  margin-bottom: 4rpx;
}

.analysis-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text, #1A1D26);
}

/* 使用情况 */
.usage-content {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.usage-item {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: center;
}

.usage-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.usage-info {
  display: flex;
  flex-direction: column;
}

.usage-label {
  font-size: 20rpx;
  color: var(--color-text-secondary, #6B7280);
  margin-bottom: 4rpx;
}

.usage-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text, #1A1D26);
}

.usage-divider {
  width: 2rpx;
  height: 60rpx;
  background: var(--color-border, #F0F2F5);
  margin: 0 8rpx;
}

/* 分类排行 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--color-bg, #F5F7FA);
  border-radius: var(--radius-lg, 24rpx);
}

.rank-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-border, #F0F2F5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-secondary, #6B7280);
  margin-right: 16rpx;
}

.rank-num.top {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #FFF;
}

.rank-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.rank-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.rank-name {
  font-size: 24rpx;
  color: var(--color-text, #1A1D26);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.rank-bar-bg {
  height: 8rpx;
  background: var(--color-border, #F0F2F5);
  border-radius: 4rpx;
  overflow: hidden;
}

.rank-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary, #2563EB) 0%, var(--color-primary-light, #3B82F6) 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.rank-amount {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
}

.rank-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text, #1A1D26);
  margin-bottom: 4rpx;
}

.rank-percent {
  font-size: 20rpx;
  color: var(--color-text-secondary, #6B7280);
}

/* 鼓励语 */
.encourage-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 28rpx;
}

.encourage-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.encourage-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #6B7280);
  text-align: center;
  line-height: 1.6;
}

/* ========== 骨架屏样式 ========== */
.skeleton-card {
  height: 200rpx;
  background: var(--color-card, #FFFFFF);
  border-radius: var(--radius-xl, 32rpx);
  margin-bottom: 20rpx;
  background: linear-gradient(90deg, #F0F2F5 25%, #E5E7EB 50%, #F0F2F5 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}