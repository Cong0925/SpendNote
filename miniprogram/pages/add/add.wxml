<!--pages/add/add.wxml-->
<view class="container">
  <!-- 类型切换：滑块式分段控件 -->
  <view class="type-switch animate-fadeIn">
    <view class="type-track">
      <view class="type-indicator {{type === 'income' ? 'right' : ''}}"></view>
      <view class="type-btn {{type === 'expense' ? 'active' : ''}}" bindtap="switchType" data-type="expense">
        <text class="type-label">支出</text>
      </view>
      <view class="type-btn {{type === 'income' ? 'active' : ''}}" bindtap="switchType" data-type="income">
        <text class="type-label">收入</text>
      </view>
    </view>
  </view>

  <!-- 金额输入 -->
  <view class="amount-card animate-slideUp" style="animation-delay: 0.05s">
    <text class="currency">¥</text>
    <input
      class="amount-field"
      type="digit"
      placeholder="0.00"
      value="{{amount}}"
      bindinput="inputAmount"
      focus="{{true}}"
    />
    <view class="amount-underline {{type}}"></view>
  </view>

  <!-- 分类选择 -->
  <view class="section animate-slideUp" style="animation-delay: 0.1s">
    <text class="section-title">选择分类</text>
    <view class="category-grid">
      <view
        class="category-item {{category === item.name ? 'active ' + type + '-active' : ''}}"
        wx:for="{{categories}}"
        wx:key="name"
        bindtap="selectCategory"
        data-name="{{item.name}}"
        data-icon="{{item.icon}}"
      >
        <view class="category-icon-wrap">
          <text class="category-icon">{{item.icon}}</text>
        </view>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 日期 & 备注 -->
  <view class="detail-card animate-slideUp" style="animation-delay: 0.15s">
    <view class="detail-row">
      <text class="detail-label">📅 日期</text>
      <picker mode="date" value="{{date}}" bindchange="changeDate">
        <view class="detail-value">
          <text>{{date}}</text>
          <text class="detail-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="detail-divider"></view>
    <view class="detail-row">
      <text class="detail-label">✏️ 备注</text>
      <input
        class="detail-input"
        placeholder="添加备注..."
        value="{{note}}"
        bindinput="inputNote"
        maxlength="50"
      />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section animate-slideUp" style="animation-delay: 0.2s">
    <button
      class="submit-btn {{type}} {{amount && category ? 'ready' : ''}}"
      bindtap="submitBill"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      <text wx:if="{{!loading}}">{{isEdit ? '修改' : '保存'}}{{type === 'expense' ? '支出' : '收入'}}</text>
      <text wx:else>{{isEdit ? '修改中...' : '保存中...'}}</text>
    </button>
  </view>
</view>
