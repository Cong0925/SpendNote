<!--
  借款记账页面 - 与现有页面统一风格
-->
<view class="container">
  <!-- 顶部区域 -->
  <view class="hero-card">
    <!-- 类型切换 -->
    <view class="type-tabs">
      <view
        class="type-tab {{currentType === 'lend' ? 'active' : ''}}"
        data-type="lend"
        bindtap="switchType"
      >
        <text>借出</text>
      </view>
      <view
        class="type-tab {{currentType === 'borrow' ? 'active' : ''}}"
        data-type="borrow"
        bindtap="switchType"
      >
        <text>借入</text>
      </view>
    </view>

    <!-- 金额显示 -->
    <view class="amount-display">
      <text class="amount-value">{{currentType === 'lend' ? summary.lendReceivable : summary.borrowRepayable}}</text>
      <text class="amount-label">({{currentType === 'lend' ? '还应收' : '还应还'}})</text>
    </view>
  </view>

  <!-- 借款记录列表 -->
  <view class="loan-list" wx:if="{{!loading}}">
    <view
      class="loan-item"
      wx:for="{{loanList}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="goToLoanDetail"
    >
      <view class="loan-left">
        <view class="loan-icon {{currentType === 'lend' ? 'lend-icon' : 'borrow-icon'}}">
          <image
            class="loan-icon-img"
            src="{{currentType === 'lend' ? '/images/loan/lend.png' : '/images/loan/borrow.png'}}"
            mode="aspectFit"
          />
        </view>
        <view class="loan-info">
          <text class="loan-person">{{item.personName}}</text>
          <text class="loan-date">{{item.loanDate}}</text>
        </view>
      </view>
      <view class="loan-right">
        <text class="loan-total">{{item.amount}}</text>
        <view class="loan-status">
          <text>应收:{{item.amount - item.paidAmount}}</text>
          <text> 已收:{{item.paidAmount}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{loanList.length === 0}}">
      <text class="empty-text">暂无{{currentType === 'lend' ? '借出' : '借入'}}记录</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
  </view>

  <!-- 新建按钮 -->
  <view class="add-btn" bindtap="goToAddLoan">
    <text>新建{{currentType === 'lend' ? '借出' : '借入'}}</text>
  </view>
</view>
