/**
 * 借款记账页面样式 - 与现有页面统一
 */
page {
  background: var(--color-bg);
}

.container {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* ============ 顶部区域 ============ */
.hero-card {
  background: linear-gradient(135deg, #2563EB 0%, #1E40AF 50%, #1E3A8A 100%);
  border-radius: var(--radius-xl);
  padding: 40rpx;
  margin: 24rpx 32rpx 0;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.3);
}

.hero-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.hero-card::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: 30%;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

/* ============ 类型切换 ============ */
.type-tabs {
  display: inline-flex;
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-full);
  padding: 6rpx;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.type-tab {
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  border-radius: var(--radius-full);
  transition: all 0.3s ease;
  font-weight: 500;
}

.type-tab.active {
  background: #ffffff;
  color: var(--color-primary);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* ============ 金额显示 ============ */
.amount-display {
  color: #ffffff;
  position: relative;
  z-index: 1;
}

.amount-value {
  font-size: 72rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: -3rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.amount-label {
  font-size: 26rpx;
  opacity: 0.8;
  font-weight: 500;
}

/* ============ 借款记录列表 ============ */
.loan-list {
  background: var(--color-card);
  margin: 24rpx 32rpx 0;
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  animation: slideUp 0.5s ease-out both;
}

.loan-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
  transition: all 0.2s ease;
}

.loan-item:last-child {
  border-bottom: none;
}

.loan-item:active {
  background: var(--color-bg);
  transform: scale(0.98);
}

.loan-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.loan-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.loan-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.lend-icon {
  background: linear-gradient(135deg, #EC4899 0%, #BE185D 100%);
}

.borrow-icon {
  background: linear-gradient(135deg, #10B981 0%, #047857 100%);
}

.loan-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.loan-person {
  font-size: 30rpx;
  color: var(--color-text);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.loan-date {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.loan-right {
  text-align: right;
  flex-shrink: 0;
}

.loan-total {
  font-size: 32rpx;
  color: var(--color-text);
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
  letter-spacing: -0.5rpx;
}

.loan-status {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* ============ 空状态 ============ */
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

/* ============ 加载状态 ============ */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* ============ 新建按钮 ============ */
.add-btn {
  position: fixed;
  bottom: 48rpx;
  left: 32rpx;
  right: 32rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
  transition: all 0.2s ease;
}

.add-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ============ 动画效果 ============ */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(32rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
