/**
 * 新建借款页面样式 - 与现有页面统一
 */
page {
  background: var(--color-bg);
}

.container {
  min-height: 100vh;
}

/* ============ 顶部标题 ============ */
.header {
  padding: 32rpx;
  padding-bottom: 20rpx;
}

.header-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 1.5rpx;
}

/* ============ 类型切换 ============ */
.type-tabs {
  display: flex;
  background: var(--color-card);
  margin: 0 32rpx 24rpx;
  border-radius: var(--radius-full);
  padding: 6rpx;
  box-shadow: var(--shadow-card);
  animation: slideUp 0.5s ease-out both;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-radius: var(--radius-full);
  font-weight: 500;
  transition: all 0.3s ease;
}

.type-tab.active {
  background: var(--color-text);
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(26, 26, 26, 0.15);
}

/* ============ 表单区域 ============ */
.form-section {
  background: var(--color-card);
  margin: 0 32rpx 24rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  animation: slideUp 0.5s ease-out both;
  animation-delay: 0.1s;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text);
  text-align: right;
}

.form-picker {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  font-size: 30rpx;
  color: var(--color-text);
}

.picker-arrow {
  margin-left: 12rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}

/* ============ 图片区域 ============ */
.image-section {
  background: var(--color-card);
  margin: 0 32rpx 24rpx;
  border-radius: var(--radius-xl);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  animation: slideUp 0.5s ease-out both;
  animation-delay: 0.2s;
}

.image-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.image-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 1.5rpx;
}

.image-count {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.image-list {
  display: flex;
  flex-wrap: wrap;
}

.image-item {
  width: 150rpx;
  height: 150rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
  animation: scaleIn 0.3s ease-out both;
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  font-size: 28rpx;
  text-align: center;
  line-height: 40rpx;
}

.add-image-btn {
  width: 150rpx;
  height: 150rpx;
  background: var(--color-bg);
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s ease;
}

.add-image-btn:active {
  background: var(--color-card);
  border-color: var(--color-primary);
}

.add-icon {
  font-size: 56rpx;
  color: var(--color-text-tertiary);
}

/* ============ 保存按钮 ============ */
.save-btn {
  margin: 48rpx 32rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
  transition: all 0.2s ease;
  animation: slideUp 0.5s ease-out both;
  animation-delay: 0.3s;
}

.save-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ============ 动画效果 ============ */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(32rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
