<!--pages/rating/rating.wxml - Optimized Rating Display -->
<view class="rating-page">
  <scroll-view class="scroll-area" scroll-y show-scrollbar="{{false}}" bounces="{{false}}">

    <!-- 骨架屏：初次加载时显示 -->
    <view class="skeleton-container" wx:if="{{showSkeleton}}">
      <!-- 评分统计骨架 -->
      <view class="skeleton-stats-card">
        <view class="skeleton-stats-main">
          <view class="skeleton-stats-score">
            <view class="skeleton-line skeleton-score-num"></view>
            <view class="skeleton-line skeleton-score-unit"></view>
          </view>
          <view class="skeleton-stats-stars">
            <view class="skeleton-star" wx:for="{{5}}" wx:key="index"></view>
          </view>
          <view class="skeleton-line skeleton-stats-count"></view>
        </view>
        <view class="skeleton-stats-bar">
          <view class="skeleton-bar-item" wx:for="{{3}}" wx:key="index">
            <view class="skeleton-line skeleton-bar-label"></view>
            <view class="skeleton-bar-track">
              <view class="skeleton-bar-fill"></view>
            </view>
            <view class="skeleton-line skeleton-bar-num"></view>
          </view>
        </view>
      </view>

      <!-- 筛选栏骨架 -->
      <view class="skeleton-filter-section">
        <view class="skeleton-filter-wrap">
          <view class="skeleton-filter-chip" wx:for="{{5}}" wx:key="index"></view>
        </view>
      </view>

      <!-- 评价列表骨架 -->
      <view class="skeleton-review-list">
        <view class="skeleton-review-card" wx:for="{{3}}" wx:key="index">
          <!-- 卡片头部 -->
          <view class="skeleton-card-header">
            <view class="skeleton-header-left">
              <view class="skeleton-user-avatar"></view>
              <view class="skeleton-user-info">
                <view class="skeleton-line skeleton-user-name"></view>
                <view class="skeleton-line skeleton-review-time"></view>
              </view>
            </view>
            <view class="skeleton-rating-badge"></view>
          </view>

          <!-- 星星评级 -->
          <view class="skeleton-card-stars">
            <view class="skeleton-star" wx:for="{{5}}" wx:key="index"></view>
            <view class="skeleton-line skeleton-star-text"></view>
          </view>

          <!-- 标签 -->
          <view class="skeleton-card-tags">
            <view class="skeleton-tag-item" wx:for="{{3}}" wx:key="index"></view>
          </view>

          <!-- 评价内容 -->
          <view class="skeleton-card-content">
            <view class="skeleton-line skeleton-content-line" style="width: 100%;"></view>
            <view class="skeleton-line skeleton-content-line" style="width: 80%;"></view>
            <view class="skeleton-line skeleton-content-line" style="width: 60%;"></view>
          </view>

          <!-- 图片 -->
          <view class="skeleton-card-images">
            <view class="skeleton-review-image" wx:for="{{2}}" wx:key="index"></view>
          </view>

          <!-- 点赞踩按钮 -->
          <view class="skeleton-card-actions">
            <view class="skeleton-action-item"></view>
            <view class="skeleton-action-item"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 评分区域 - 编辑模式时显示 -->
    <view class="rating-card" wx:if="{{isEditing}}">
      <view class="rating-header">{{hasSubmitted ? '修改我的评价' : '请为 SpendNote 评分'}}</view>
      <view class="star-row">
        <view
          wx:for="{{[1,2,3,4,5]}}"
          wx:key="*this"
          class="star-item"
          catchtap="onTapStar"
          data-star="{{item}}"
        >
          <text class="star {{item <= userRating ? 'active' : ''}}">★</text>
        </view>
      </view>
      <view class="rating-hint">{{ratingText}}</view>
    </view>

    <!-- 标签选择 - 编辑模式时显示 -->
    <view class="section-card" wx:if="{{isEditing}}">
      <view class="section-title">选择亮点标签</view>
      <view class="tags-wrap">
        <view
          wx:for="{{tags}}"
          wx:key="id"
          class="tag-chip {{item.isActive ? 'active' : ''}}"
          catchtap="onTapTag"
          data-id="{{item.id}}"
          data-text="{{item.text}}"
        >
          <text class="tag-icon">{{item.icon}}</text>
          <text class="tag-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- 评论输入 - 编辑模式时显示 -->
    <view class="section-card" wx:if="{{isEditing}}">
      <view class="section-title">写下你的评价</view>
      <view class="input-area">
        <textarea
          class="comment-input"
          placeholder="点击上方标签可快速添加到评价..."
          maxlength="200"
          bindinput="onCommentInput"
          value="{{comment}}"
        />
        <view class="input-footer">
          <text class="char-count">{{comment.length}}/200</text>
        </view>
      </view>

      <!-- 图片上传 -->
      <view class="image-section">
        <view class="image-list">
          <view wx:for="{{uploadedImages}}" wx:key="index" class="image-item">
            <view class="image-thumb-wrapper">
              <!-- 图片加载失败时显示占位图 -->
              <view class="image-error-slot-small" wx:if="{{imageErrorMap['my'] && imageErrorMap['my'][index]}}">
                <text class="error-icon-small">🖼️</text>
              </view>
              <!-- 正常显示图片 -->
              <image
                wx:else
                src="{{item}}"
                class="image-thumb"
                mode="aspectFill"
                data-url="{{item}}"
                data-img-idx="{{index}}"
                bindtap="onPreviewImage"
                binderror="onMyImageError"
              />
            </view>
            <view class="image-delete" catchtap="onDeleteImage" data-index="{{index}}">×</view>
          </view>
          <view class="image-add" wx:if="{{uploadedImages.length < 3}}" bindtap="onChooseImage">
            <text class="add-icon">+</text>
            <text class="add-text">添加图片</text>
          </view>
        </view>
        <text class="image-hint">最多上传 3 张图片（可选）</text>
      </view>
    </view>

    <!-- 提交按钮 - 新增评价时显示 -->
    <view class="submit-wrap" wx:if="{{isEditing && !hasSubmitted}}">
      <button
        class="submit-btn {{userRating > 0 ? 'active' : ''}}"
        bindtap="onSubmit"
        disabled="{{!userRating || isSubmitting}}"
      >
        <text wx:if="{{!isSubmitting}}">提交评价</text>
        <text wx:else>提交中...</text>
      </button>
    </view>

    <!-- 保存/取消按钮 - 修改评价时显示 -->
    <view class="save-cancel-wrap" wx:if="{{isEditing && hasSubmitted}}">
      <button class="cancel-btn" bindtap="onCancelEdit">取消</button>
      <button
        class="save-btn {{userRating > 0 ? 'active' : ''}}"
        bindtap="onSubmit"
        disabled="{{!userRating || isSubmitting}}"
      >
        <text wx:if="{{!isSubmitting}}">保存修改</text>
        <text wx:else>保存中...</text>
      </button>
    </view>

    <!-- 评分统计展示 - 非编辑模式且骨架屏隐藏时显示 -->
    <view class="stats-showcase" wx:if="{{!isEditing && !showSkeleton}}">
      <view class="stats-main">
        <view class="stats-score">
          <text class="score-num">{{avgRating || '0.0'}}</text>
          <text class="score-unit">分</text>
        </view>
        <view class="stats-stars">
          <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="star {{item <= avgRating ? 'active' : ''}}">★</text>
        </view>
        <view class="stats-count">共 {{totalCount}} 人评价</view>
      </view>
      <view class="stats-bar">
        <view class="bar-item">
          <text class="bar-label">好评</text>
          <view class="bar-track">
            <view class="bar-fill good" style="width: {{totalCount > 0 ? goodCount / totalCount * 100 : 0}}%"></view>
          </view>
          <text class="bar-num">{{goodCount}}</text>
        </view>
        <view class="bar-item">
          <text class="bar-label">中评</text>
          <view class="bar-track">
            <view class="bar-fill mid" style="width: {{totalCount > 0 ? midCount / totalCount * 100 : 0}}%"></view>
          </view>
          <text class="bar-num">{{midCount}}</text>
        </view>
        <view class="bar-item">
          <text class="bar-label">差评</text>
          <view class="bar-track">
            <view class="bar-fill bad" style="width: {{totalCount > 0 ? badCount / totalCount * 100 : 0}}%"></view>
          </view>
          <text class="bar-num">{{badCount}}</text>
        </view>
      </view>
    </view>

    <!-- 筛选栏 - 非编辑模式且骨架屏隐藏时显示 -->
    <view class="filter-section" wx:if="{{!isEditing && !showSkeleton}}">
      <view class="filter-wrap">
        <view class="filter-chip {{currentFilter === 'all' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="all">
          <text>全部</text>
          <view class="filter-num">{{totalCount}}</view>
        </view>
        <view class="filter-chip {{currentFilter === 'good' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="good">
          <text>👍 好评</text>
          <view class="filter-num">{{goodCount}}</view>
        </view>
        <view class="filter-chip {{currentFilter === 'mid' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="mid">
          <text>😐 中评</text>
          <view class="filter-num">{{midCount}}</view>
        </view>
        <view class="filter-chip {{currentFilter === 'bad' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="bad">
          <text>👎 差评</text>
          <view class="filter-num">{{badCount}}</view>
        </view>
        <view class="filter-chip {{currentFilter === 'hasImage' ? 'active' : ''}}" bindtap="onFilterChange" data-filter="hasImage">
          <text>🖼️ 有图</text>
          <view class="filter-num">{{hasImageCount}}</view>
        </view>
      </view>
    </view>

    <!-- 添加评价入口 - 未评价且非编辑模式且骨架屏隐藏时显示 -->
    <view class="add-rating-entry" wx:if="{{!hasSubmitted && !isEditing && !showSkeleton}}" bindtap="onAddRating" hidden="{{isEditing}}">
      <view class="entry-bg"></view>
      <view class="entry-content">
        <view class="entry-left">
          <view class="entry-icon-wrap">
            <text class="entry-icon">✍️</text>
          </view>
          <view class="entry-info">
            <text class="entry-title">分享你的使用体验</text>
            <text class="entry-desc">你的评价能帮助更多人了解 SpendNote</text>
          </view>
        </view>
        <view class="entry-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>

    <!-- 骨架屏：切换筛选时只显示列表骨架 -->
    <view class="skeleton-review-list" wx:if="{{showListSkeleton && !showSkeleton}}">
      <view class="skeleton-review-card" wx:for="{{3}}" wx:key="index">
        <!-- 卡片头部 -->
        <view class="skeleton-card-header">
          <view class="skeleton-header-left">
            <view class="skeleton-user-avatar"></view>
            <view class="skeleton-user-info">
              <view class="skeleton-line skeleton-user-name"></view>
              <view class="skeleton-line skeleton-review-time"></view>
            </view>
          </view>
          <view class="skeleton-rating-badge"></view>
        </view>

        <!-- 星星评级 -->
        <view class="skeleton-card-stars">
          <view class="skeleton-star" wx:for="{{5}}" wx:key="index"></view>
          <view class="skeleton-line skeleton-star-text"></view>
        </view>

        <!-- 标签 -->
        <view class="skeleton-card-tags">
          <view class="skeleton-tag-item" wx:for="{{3}}" wx:key="index"></view>
        </view>

        <!-- 评价内容 -->
        <view class="skeleton-card-content">
          <view class="skeleton-line skeleton-content-line" style="width: 100%;"></view>
          <view class="skeleton-line skeleton-content-line" style="width: 80%;"></view>
          <view class="skeleton-line skeleton-content-line" style="width: 60%;"></view>
        </view>

        <!-- 图片 -->
        <view class="skeleton-card-images">
          <view class="skeleton-review-image" wx:for="{{2}}" wx:key="index"></view>
        </view>

        <!-- 点赞踩按钮 -->
        <view class="skeleton-card-actions">
          <view class="skeleton-action-item"></view>
          <view class="skeleton-action-item"></view>
        </view>
      </view>
    </view>

    <!-- 评价列表 - 非编辑模式且骨架屏隐藏时显示 -->
    <view class="review-list" wx:if="{{!isEditing && !showListSkeleton && !showSkeleton}}">
      <view wx:for="{{filteredReviews}}" wx:key="_id" class="review-card {{item.isMine ? 'my-review' : ''}}">
        <!-- 卡片头部 -->
        <view class="card-header">
          <view class="header-left">
            <view class="user-avatar">
              <text>👤</text>
            </view>
            <view class="user-info">
              <text class="user-name">{{item.isMine ? '我' : '匿名用户'}}</text>
              <text class="review-time">{{item.createTimeStr}}</text>
            </view>
          </view>
          <view class="header-right">
            <!-- 我的评价显示修改/删除按钮 -->
            <view class="my-review-actions" wx:if="{{item.isMine && !isEditing}}">
              <text class="action-btn modify" bindtap="onModifyRating">修改</text>
              <text class="action-btn delete" bindtap="onDeleteRating">删除</text>
            </view>
            <view class="rating-badge {{item.rating >= 4 ? 'good' : item.rating === 3 ? 'mid' : 'bad'}}" wx:else>
              <text>{{item.rating}}分</text>
            </view>
          </view>
        </view>

        <!-- 星星评级 -->
        <view class="card-stars">
          <text wx:for="{{[1,2,3,4,5]}}" wx:for-item="star" wx:for-index="starIdx" wx:key="starIdx" class="star {{star <= item.rating ? 'active' : ''}}">★</text>
          <text class="star-text">{{item.rating >= 4 ? '好评' : item.rating === 3 ? '中评' : '差评'}}</text>
        </view>

        <!-- 标签 -->
        <view class="card-tags" wx:if="{{item.tags && item.tags.length > 0}}">
          <view wx:for="{{item.tags}}" wx:for-item="tag" wx:for-index="tagIdx" wx:key="id" class="tag-item">
            <text class="tag-icon">{{tag.icon}}</text>
            <text class="tag-text">{{tag.text}}</text>
          </view>
        </view>

        <!-- 评价内容 -->
        <view class="card-content" wx:if="{{item.comment}}">
          <text>{{item.comment}}</text>
        </view>

        <!-- 图片 -->
        <view class="card-images" wx:if="{{item.images && item.images.length > 0}}">
          <view wx:for="{{item.images}}" wx:for-item="img" wx:for-index="imgIdx" wx:key="imgIdx" class="review-image-wrapper">
            <!-- 图片加载失败时显示占位图 -->
            <view class="image-error-slot" wx:if="{{imageErrorMap[item._id] && imageErrorMap[item._id][imgIdx]}}">
              <text class="error-icon">🖼️</text>
              <text class="error-text">图片加载失败</text>
            </view>
            <!-- 正常显示图片 -->
            <image
              wx:else
              src="{{img}}"
              class="review-image"
              mode="aspectFill"
              data-url="{{img}}"
              data-review-idx="{{item._id}}"
              data-img-idx="{{imgIdx}}"
              bindtap="onPreviewReviewImage"
              binderror="onImageError"
            />
          </view>
        </view>

        <!-- 点赞踩按钮 - 只有非自己的评价才显示 -->
        <view class="card-actions" wx:if="{{!item.isMine}}">
          <view class="action-item {{item.isLiked ? 'active' : ''}}" catchtap="onLike" data-id="{{item._id}}">
            <text class="action-icon">{{item.isLiked ? '👍' : '👍🏻'}}</text>
            <text class="action-num">{{item.likes || 0}}</text>
          </view>
          <view class="action-item {{item.isDisliked ? 'active' : ''}}" catchtap="onDislike" data-id="{{item._id}}">
            <text class="action-icon">{{item.isDisliked ? '👎' : '👎🏻'}}</text>
            <text class="action-num">{{item.dislikes || 0}}</text>
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{hasMore && !loading}}" bindtap="onLoadMore">
        <text>加载更多</text>
      </view>

      <!-- 加载中 -->
      <view class="loading-state" wx:if="{{loading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>

      <!-- 暂无评价 -->
      <view class="empty-state" wx:if="{{!loading && filteredReviews.length === 0}}">
        <view class="empty-icon">📭</view>
        <view class="empty-text">暂无{{currentFilter === 'good' ? '好评' : currentFilter === 'mid' ? '中评' : currentFilter === 'bad' ? '差评' : currentFilter === 'hasImage' ? '带图' : ''}}评价</view>
      </view>
    </view>

  </scroll-view>
</view>