/* pages/mine/mine.wxss - Premium Profile Page */
page {
  background: var(--color-bg);
}

.container {
  padding: 32rpx;
  padding-bottom: 160rpx;
  background: var(--color-bg);
  min-height: 100vh;
}

/* ============ 用户卡片 ============ */
.profile-card {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.2);
}

.profile-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #2563EB 0%, #1E40AF 50%, #1E3A8A 100%);
  z-index: 0;
}

.profile-bg::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.profile-bg::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: 40%;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.profile-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 40rpx 36rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: #ffffff;
  letter-spacing: 0.5rpx;
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.5rpx;
}

/* ============ 数据总览 ============ */
.overview-card {
  background: var(--color-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
}

.overview-header {
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.overview-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.stat-icon-wrap.expense {
  background: var(--color-expense-light);
}

.stat-icon-wrap.income {
  background: var(--color-income-light);
}

.stat-icon {
  font-size: 28rpx;
}

.stat-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 6rpx;
  letter-spacing: -0.5rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.stat-amount.expense { color: var(--color-expense); }
.stat-amount.income { color: var(--color-income); }

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.stat-divider {
  width: 1rpx;
  height: 64rpx;
  background: var(--color-divider);
}

/* ============ 功能菜单 ============ */
.menu-card {
  background: var(--color-card);
  border-radius: var(--radius-xl);
  padding: 0 32rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-card);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  transition: all 0.2s ease;
}

.menu-item:active {
  opacity: 0.6;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon-wrap.danger {
  background: var(--color-expense-light);
}

.menu-icon {
  font-size: 28rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.menu-text.danger {
  color: var(--color-danger);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--color-text-light);
  font-weight: 300;
}

.menu-arrow.danger {
  color: var(--color-danger);
}

.menu-divider {
  height: 1rpx;
  background: var(--color-divider);
  margin-left: 84rpx;
}

.menu-item.danger .menu-text {
  color: var(--color-danger);
}

/* ============ 版本信息 ============ */
.version-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 48rpx;
}

.version-badge {
  padding: 8rpx 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sm);
  margin-bottom: 12rpx;
}

.version-badge text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
  letter-spacing: 1rpx;
}

.version-sub {
  font-size: 22rpx;
  color: var(--color-text-light);
  letter-spacing: 2rpx;
}

/* ============ 页面动画 ============ */
.container {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}
