/* pages/mine/mine.wxss - Premium Profile Page */
page {
  background: var(--color-bg);
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.scroll-area {
  flex: 1;
  overflow: hidden;
  background: var(--color-bg);
  box-sizing: border-box;
}

/* ============ 用户卡片 ============ */
.profile-card {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.2);
}

.profile-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #2563EB 0%, #1E40AF 50%, #1E3A8A 100%);
  z-index: 0;
}

.profile-bg::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.profile-bg::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: 40%;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.profile-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 40rpx 36rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: #ffffff;
  letter-spacing: 0.5rpx;
}

.user-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.5rpx;
}

/* ============ 数据总览 ============ */
.overview-card {
  background: var(--color-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
}

.overview-header {
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.overview-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.stat-icon-wrap.expense {
  background: var(--color-expense-light);
}

.stat-icon-wrap.income {
  background: var(--color-income-light);
}

.stat-icon {
  font-size: 28rpx;
}

.stat-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 6rpx;
  letter-spacing: -0.5rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.stat-amount.expense { color: var(--color-expense); }
.stat-amount.income { color: var(--color-income); }

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.stat-divider {
  width: 1rpx;
  height: 64rpx;
  background: var(--color-divider);
}

/* ============ 功能菜单 ============ */
.menu-card {
  background: var(--color-card);
  border-radius: var(--radius-xl);
  padding: 0 32rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-card);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  transition: all 0.2s ease;
}

.menu-item:active {
  opacity: 0.6;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon-wrap.danger {
  background: var(--color-expense-light);
}

.menu-icon {
  font-size: 28rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.menu-text.danger {
  color: var(--color-danger);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--color-text-light);
  font-weight: 300;
}

.menu-arrow.danger {
  color: var(--color-danger);
}

.menu-divider {
  height: 1rpx;
  background: var(--color-divider);
  margin-left: 84rpx;
}

.menu-item.danger .menu-text {
  color: var(--color-danger);
}

/* ============ 版本信息 ============ */
.version-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 48rpx;
}

.version-badge {
  padding: 8rpx 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-sm);
  margin-bottom: 12rpx;
}

.version-badge text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
  letter-spacing: 1rpx;
}

.version-sub {
  font-size: 22rpx;
  color: var(--color-text-light);
  letter-spacing: 2rpx;
}

/* ============ 页面动画 ============ */
.container {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ============ 清除数据弹窗 ============ */
.clear-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.25s ease-out;
  backdrop-filter: blur(8rpx);
}

.clear-modal {
  width: 620rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.25);
  animation: modalSlideUp 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalSlideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* 顶部图标 */
.clear-modal-icon-wrap {
  position: relative;
  display: flex;
  justify-content: center;
  padding-top: 48rpx;
  margin-bottom: 8rpx;
}

.clear-modal-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #FEE2E2 0%, #FECACA 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  box-shadow: 0 8rpx 24rpx rgba(220, 38, 38, 0.2);
}

.icon-trash {
  font-size: 52rpx;
  filter: grayscale(20%);
}

.clear-modal-icon-ring {
  position: absolute;
  top: 40rpx;
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(220, 38, 38, 0.15);
  animation: ringPulse 2s ease-in-out infinite;
}

@keyframes ringPulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.08); opacity: 0.5; }
}

/* 标题区域 */
.clear-modal-header {
  text-align: center;
  padding: 16rpx 40rpx 8rpx;
}

.clear-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
  letter-spacing: -0.5rpx;
  display: block;
  margin-bottom: 8rpx;
}

.clear-modal-subtitle {
  font-size: 26rpx;
  color: #9CA3AF;
  letter-spacing: 0.5rpx;
}

/* 内容区域 */
.clear-modal-body {
  padding: 24rpx 40rpx 32rpx;
}

/* 数据统计卡片 */
.clear-stats-card {
  background: linear-gradient(145deg, #F9FAFB 0%, #F3F4F6 100%);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-number {
  font-size: 44rpx;
  font-weight: 800;
  color: #DC2626;
  letter-spacing: -1rpx;
  font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, sans-serif;
  line-height: 1.1;
  margin-bottom: 6rpx;
}

.stats-label {
  font-size: 22rpx;
  color: #6B7280;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.stats-total {
  text-align: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.stats-total-text {
  font-size: 24rpx;
  color: #6B7280;
}

.stats-total-number {
  font-weight: 700;
  color: #DC2626;
}

/* 警告卡片 */
.clear-warning-card {
  display: flex;
  align-items: center;
  background: #FEF2F2;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(220, 38, 38, 0.1);
}

.warning-icon-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #DC2626;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.warning-icon-circle text {
  font-size: 28rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
}

.warning-content {
  display: flex;
  flex-direction: column;
}

.warning-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #991B1B;
  margin-bottom: 4rpx;
}

.warning-desc {
  font-size: 22rpx;
  color: #B91C1C;
  line-height: 1.4;
}

/* 删除清单 */
.delete-checklist {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.checklist-header {
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #FEF2F2 0%, #FEE2E2 100%);
  border-bottom: 1rpx solid rgba(220, 38, 38, 0.1);
}

.checklist-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #991B1B;
  letter-spacing: 0.5rpx;
}

.checklist-items {
  padding: 8rpx 0;
}

.checklist-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.checklist-item:last-child {
  border-bottom: none;
}

.item-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-icon text {
  font-size: 26rpx;
}

.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.item-desc {
  font-size: 22rpx;
  color: #9CA3AF;
}

.item-badge {
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.item-badge.danger {
  background: #FEE2E2;
}

.item-badge.danger text {
  font-size: 20rpx;
  font-weight: 600;
  color: #DC2626;
}

/* 最终警告框 */
.final-warning-box {
  display: flex;
  background: #FFFBEB;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.warning-stripe {
  width: 8rpx;
  background: linear-gradient(180deg, #F59E0B 0%, #D97706 100%);
  flex-shrink: 0;
}

.warning-body {
  display: flex;
  align-items: center;
  padding: 20rpx 20rpx 20rpx 16rpx;
  flex: 1;
}

.warning-icon-wrap {
  margin-right: 14rpx;
  flex-shrink: 0;
}

.warning-emoji {
  font-size: 32rpx;
}

.warning-text-wrap {
  display: flex;
  flex-direction: column;
}

.warning-main {
  font-size: 26rpx;
  font-weight: 600;
  color: #92400E;
  margin-bottom: 4rpx;
}

.warning-sub {
  font-size: 22rpx;
  color: #A16207;
  line-height: 1.4;
}

/* 底部按钮 */
.clear-modal-footer {
  display: flex;
  padding: 8rpx 32rpx 40rpx;
  gap: 16rpx;
}

.clear-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 0.5rpx;
  transition: all 0.2s ease;
}

.clear-btn:active {
  transform: scale(0.97);
}

.clear-btn.cancel {
  background: #F3F4F6;
  color: #6B7280;
}

.clear-btn.cancel:active {
  background: #E5E7EB;
}

.clear-btn.next {
  background: linear-gradient(145deg, #3B82F6 0%, #2563EB 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
}

.clear-btn.next:active {
  background: linear-gradient(145deg, #2563EB 0%, #1D4ED8 100%);
}

.clear-btn.danger {
  background: linear-gradient(145deg, #EF4444 0%, #DC2626 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(220, 38, 38, 0.3);
}

.clear-btn.danger:active {
  background: linear-gradient(145deg, #DC2626 0%, #B91C1C 100%);
}

.clear-btn::after {
  border: none;
}
