/**
 * 收款/还款操作页面样式 - 与现有页面统一
 */
page {
  background: var(--color-bg);
}

.container {
  min-height: 100vh;
}

/* ============ 借款信息 ============ */
.loan-info {
  background: linear-gradient(135deg, #2563EB 0%, #1E40AF 50%, #1E3A8A 100%);
  border-radius: var(--radius-xl);
  padding: 40rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.3);
  animation: slideUp 0.5s ease-out both;
}

.loan-info::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.loan-info::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: 30%;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
  position: relative;
  z-index: 1;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row.highlight {
  background: rgba(255, 255, 255, 0.1);
  margin: 0 -40rpx;
  padding: 24rpx 40rpx;
  border-radius: var(--radius-md);
}

.info-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.info-value {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
  letter-spacing: -0.5rpx;
}

.info-row.highlight .info-value {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
}

/* ============ 表单卡片 ============ */
.form-card {
  background: var(--color-card);
  border-radius: var(--radius-xl);
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  animation: slideUp 0.5s ease-out 0.1s both;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input-wrapper {
  display: flex;
  align-items: center;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  height: 88rpx;
  background: var(--color-card);
  transition: border-color 0.2s ease;
}

.form-input-wrapper:focus-within {
  border-color: var(--color-primary);
}

.currency-symbol {
  font-size: 32rpx;
  color: var(--color-text);
  margin-right: 12rpx;
  font-weight: 600;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.form-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--color-text);
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-card);
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.form-picker:focus {
  border-color: var(--color-primary);
}

.picker-arrow {
  color: var(--color-text-light);
  font-size: 24rpx;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-card);
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.form-textarea:focus {
  border-color: var(--color-primary);
}

/* ============ 详情卡片 ============ */
.detail-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 0 32rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-sm);
}

.detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
}

.detail-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.detail-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
}

.detail-value:active {
  background: var(--color-bg);
}

.detail-arrow {
  font-size: 28rpx;
  color: var(--color-text-light);
}

/* ============ 图片列表 ============ */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
}

.image-preview {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
  object-fit: cover;
}

.image-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: var(--color-danger);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.3);
}

.image-add {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--color-bg);
  transition: all 0.2s ease;
}

.image-add:active {
  background: var(--color-border);
}

.add-icon {
  font-size: 48rpx;
  color: var(--color-text-light);
  margin-bottom: 8rpx;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* ============ 保存按钮 ============ */
.save-btn {
  position: fixed;
  bottom: 48rpx;
  left: 32rpx;
  right: 32rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
  transition: all 0.2s ease;
  z-index: 100;
}

.save-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ============ 动画效果 ============ */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(32rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
