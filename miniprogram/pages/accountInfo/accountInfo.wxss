/**
 * 账户详情页面样式
 */
page {
  background: var(--color-bg);
}

.container {
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* ============ 顶部余额/应还区域 ============ */
.balance-card {
  padding: 60rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-xl);
  margin: 0 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.asset-card {
  background: linear-gradient(135deg, #2563EB 0%, #1E40AF 50%, #1E3A8A 100%);
}

.debt-card {
  background: linear-gradient(135deg, #EF4444 0%, #DC2626 50%, #B91C1C 100%);
}

.balance-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.balance-card::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: 30%;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.balance-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.balance-value {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.balance-amount {
  font-size: 72rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -3rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.edit-icon {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 16rpx;
}

/* ============ 入账/出账统计 ============ */
.stats-row {
  display: flex;
  background: var(--color-card);
  margin: 30rpx 32rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
}

.stat-item:first-child {
  border-right: 1rpx solid var(--color-divider);
}

.stat-label {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.stat-value.income {
  color: var(--color-income);
}

.stat-value.expense {
  color: var(--color-expense);
}

/* ============ 账单列表 ============ */
.bill-list {
  background: var(--color-card);
  margin: 0 32rpx 30rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.bill-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.bill-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.bill-count {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.bill-empty {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

.bill-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
  transition: all 0.2s ease;
}

.bill-item:last-child {
  border-bottom: none;
}

.bill-item:active {
  background: var(--color-bg);
  transform: scale(0.98);
}

.bill-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.bill-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
  font-size: 32rpx;
}

.income-icon {
  background: var(--color-income-light);
}

.expense-icon {
  background: var(--color-expense-light);
}

.bill-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.bill-category {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.bill-note {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bill-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.bill-amount {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.income-amount {
  color: var(--color-income);
}

.expense-amount {
  color: var(--color-expense);
}

.bill-date {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

/* ============ 底部操作按钮 ============ */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: var(--color-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: var(--radius-full);
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.delete-btn {
  background: var(--color-card);
  color: var(--color-danger);
  border: 2rpx solid var(--color-danger);
  margin-right: 24rpx;
}

.delete-btn:active {
  background: var(--color-danger);
  color: #ffffff;
}

.bill-btn {
  background: linear-gradient(135deg, var(--color-income) 0%, #059669 100%);
  color: #ffffff;
  margin-right: 24rpx;
}

.transfer-btn {
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  color: #ffffff;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
}

/* ============ 加载状态 ============ */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* ============ 动画效果 ============ */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(32rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
