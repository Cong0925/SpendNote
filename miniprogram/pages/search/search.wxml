<!--pages/search/search.wxml-->
<view class="page">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>
    <view class="nav-content">
      <view class="nav-back" bindtap="goBack">
        <view class="back-arrow"></view>
      </view>
      <text class="nav-title">搜索</text>
      <view class="nav-right"></view>
    </view>
  </view>

  <!-- 搜索区域 -->
  <view class="search-area">
    <view class="search-input-wrap">
      <input class="search-input" placeholder="输入金额、类别名或备注" value="{{searchKeyword}}" bindinput="onSearchInput" bindconfirm="doSearch" />
      <view class="search-btn" bindtap="doSearch">搜索</view>
    </view>
  </view>

  <!-- 汇总卡片 -->
  <view class="summary-card">
    <view class="summary-row">
      <text class="summary-label">搜索了</text>
      <text class="summary-value">{{searchTotal}}</text>
      <text class="summary-label">条</text>
    </view>
    <view class="summary-detail">
      <view class="summary-item">
        <text class="summary-item-label">收入</text>
        <text class="summary-item-value income">¥{{searchIncomeStr}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-item-label">支出</text>
        <text class="summary-item-value expense">¥{{searchExpenseStr}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-item-label">结余</text>
        <text class="summary-item-value {{searchBalance >= 0 ? 'income' : 'expense'}}">¥{{searchBalanceStr}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <scroll-view class="scroll-area" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{searchResult.length === 0 && searched}}">
      <view class="empty-icon">🔍</view>
      <text class="empty-title">没有搜索匹配</text>
      <text class="empty-desc">试试其他关键词</text>
    </view>

    <!-- 初始状态提示 -->
    <view class="empty-state" wx:if="{{!searched}}">
      <view class="empty-icon">💡</view>
      <text class="empty-title">输入关键词开始搜索</text>
      <text class="empty-desc">支持按金额、分类、备注搜索</text>
    </view>

    <!-- 按日期分组的搜索结果 -->
    <block wx:for="{{searchResult}}" wx:key="date">
      <!-- 日期分组标题 -->
      <view class="group-header">
        <view class="group-date">{{item.dateText}}</view>
        <view class="group-summary">
          <text class="group-income">收入 {{item.incomeStr}}</text>
          <text class="group-expense">支出 {{item.expenseStr}}</text>
          <text class="group-balance">结余 {{item.balanceStr}}</text>
        </view>
      </view>
      <!-- 该日期下的账单 -->
      <view class="bill-card" wx:for="{{item.bills}}" wx:for-item="bill" wx:key="_id" bindtap="goToDetail" data-id="{{bill._id}}">
        <view class="bill-row">
          <view class="bill-left">
            <view class="bill-icon-wrap">
              <text class="bill-icon">{{bill.icon}}</text>
            </view>
            <view class="bill-info">
              <text class="bill-name">{{bill.category}}</text>
              <text class="bill-note" wx:if="{{bill.note}}">{{bill.note}}</text>
            </view>
          </view>
          <view class="bill-right">
            <text class="bill-amount {{bill.type === 'expense' ? 'red' : 'green'}}">{{bill.amountStr}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 加载状态 -->
    <view class="load-more" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text>搜索中</text>
    </view>
  </scroll-view>
</view>
