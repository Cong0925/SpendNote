<!--pages/index/index.wxml-->
<view class="container">
  <!-- 使用自定义导航组件 -->
  <custom-nav
    title="我的账本"
    date="{{currentDate}}"
    dateText="{{dateDisplay}}"
    viewMode="{{viewMode}}"
    isRange="{{isRange}}"
    rangeStartDate="{{rangeStartDate}}"
    rangeEndDate="{{rangeEndDate}}"
    rangeStartText="{{rangeStartText}}"
    rangeEndText="{{rangeEndText}}"
    bind:rangeDateChange="handleRangeDateChange"
  />


  <!-- 快捷日期切换 -->
  <view class="quick-tabs animate-slideUp" style="animation-delay: 0.05s">
    <view
      class="quick-tab {{viewMode === item.value ? 'active' : ''}}"
      wx:for="{{viewModes}}"
      wx:key="value"
      bindtap="selectQuickTab"
      data-value="{{item.value}}"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- 收支概览卡片 -->
  <view class="hero-card animate-slideUp" style="animation-delay: 0.1s">
    <view class="hero-amounts">
      <view class="hero-amount-item">
        <text class="hero-amount-label">支出</text>
        <text class="hero-amount-value expense">¥{{totalExpenseStr}}</text>
      </view>
      <view class="hero-divider"></view>
      <view class="hero-amount-item">
        <text class="hero-amount-label">收入</text>
        <text class="hero-amount-value income">¥{{totalIncomeStr}}</text>
      </view>
    </view>
  </view>

  <!-- 账单列表标题 -->
  <view class="list-header animate-slideUp" style="animation-delay: 0.15s" wx:if="{{bills.length > 0}}">
    <text class="list-title">账单明细</text>
    <text class="list-count">共{{bills.length}}笔</text>
  </view>

  <!-- 账单列表 -->
  <view class="bill-list">
    <view class="empty-state animate-fadeIn" wx:if="{{bills.length === 0 && !loading}}">
      <view class="empty-icon">📝</view>
      <text class="empty-title">还没有记账哦</text>
      <text class="empty-desc">点击下方按钮开始记录第一笔</text>
    </view>

    <view class="swipe-wrap animate-slideUp" style="animation-delay: {{0.2 + index * 0.05}}s" wx:for="{{bills}}" wx:key="_id">
      <view class="swipe-bg" catchtap="confirmDelete" data-id="{{item._id}}">
        <text>删除</text>
      </view>
      <view class="swipe-card {{item.swiped ? 'open' : ''}}"
        catchtouchstart="onTouchStart"
        catchtouchmove="onTouchMove"
        catchtouchend="onTouchEnd"
        data-index="{{index}}">
        <view class="bill-row">
          <view class="bill-left">
            <view class="bill-icon-wrap">
              <text class="bill-icon">{{item.icon}}</text>
            </view>
            <view class="bill-info">
              <text class="bill-name">{{item.category}}</text>
              <text class="bill-note" wx:if="{{item.note}}">{{item.note}}</text>
            </view>
          </view>
          <view class="bill-right">
            <text class="bill-amount {{item.type === 'expense' ? 'red' : 'green'}}">{{item.amountStr}}</text>
            <text class="bill-date">{{item.date}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text>加载中</text>
    </view>
    <view class="load-more" wx:if="{{!hasMore && bills.length > 0}}">
      <view class="load-end-line"></view>
      <text class="load-end-text">没有更多了</text>
      <view class="load-end-line"></view>
    </view>
  </view>

  <!-- 记账按钮 -->
  <view class="fab-btn" bindtap="goToAdd">
    <text class="fab-icon">+</text>
  </view>

  <!-- 季度弹窗 -->
  <view class="quarter-mask" wx:if="{{showQuarter}}" bindtap="hideQuarterPicker"></view>
  <view class="quarter-sheet {{showQuarter ? 'show' : ''}}">
    <view class="quarter-handle"></view>
    <view class="quarter-item {{quarterIndex === item.value ? 'active' : ''}}" wx:for="{{quarters}}" wx:key="value" bindtap="selectQuarter" data-value="{{item.value}}">
      <text>{{item.label}}</text>
      <view class="quarter-check" wx:if="{{quarterIndex === item.value}}">✓</view>
    </view>
  </view>
</view>
