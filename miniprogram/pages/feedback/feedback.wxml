<!-- pages/feedback/feedback.wxml -->
<view class="feedback-page">
  <!-- 反馈列表 -->
  <scroll-view class="content-scroll" scroll-y>
    <view class="content-wrapper">
      <!-- 骨架屏 -->
      <view class="skeleton-container" wx:if="{{showSkeleton}}">
        <!-- 骨架屏：温馨提示卡片 -->
        <view class="skeleton-tip-card">
          <view class="skeleton-icon skeleton-pulse"></view>
          <view class="skeleton-tip-content">
            <view class="skeleton-title skeleton-pulse"></view>
            <view class="skeleton-text skeleton-pulse"></view>
          </view>
        </view>

        <!-- 骨架屏：反馈列表 -->
        <view class="skeleton-list">
          <view class="skeleton-item" wx:for="{{3}}" wx:key="index">
            <!-- 顶部：类型和操作按钮 -->
            <view class="skeleton-header">
              <view class="skeleton-badge skeleton-pulse"></view>
              <view class="skeleton-actions">
                <view class="skeleton-action-btn skeleton-pulse"></view>
                <view class="skeleton-action-btn skeleton-pulse"></view>
              </view>
            </view>
            <!-- 内容 -->
            <view class="skeleton-content">
              <view class="skeleton-line skeleton-pulse" style="width: 100%;"></view>
              <view class="skeleton-line skeleton-pulse" style="width: 80%;"></view>
              <view class="skeleton-line skeleton-pulse" style="width: 60%;"></view>
            </view>
            <!-- 截图 -->
            <view class="skeleton-images">
              <view class="skeleton-image skeleton-pulse"></view>
              <view class="skeleton-image skeleton-pulse"></view>
            </view>
            <!-- 底部：时间和编号 -->
            <view class="skeleton-footer">
              <view class="skeleton-time skeleton-pulse"></view>
              <view class="skeleton-id skeleton-pulse"></view>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{feedbackList.length === 0 && !loading && !showSkeleton}}">
        <view class="empty-icon-wrapper">
          <text class="empty-icon">💬</text>
        </view>
        <text class="empty-title">暂无反馈记录</text>
        <text class="empty-desc">遇到问题或有好的建议？点击下方按钮提交反馈</text>
      </view>

      <!-- 温馨提示 -->
      <view class="tip-card" wx:if="{{feedbackList.length > 0 && !showSkeleton}}">
        <view class="tip-icon">💡</view>
        <view class="tip-content">
          <text class="tip-title">温馨提示</text>
          <text class="tip-text">反馈每天定时上报至管理员邮箱，上报后将无法删除。如需删除，请在当天内操作。</text>
        </view>
      </view>

      <!-- 反馈列表 -->
      <view class="feedback-list" wx:if="{{!showSkeleton}}">
        <view class="feedback-item" wx:for="{{feedbackList}}" wx:key="_id" style="animation-delay: {{index * 0.1}}s">
          <!-- 顶部：类型和操作按钮 -->
          <view class="feedback-header">
            <view class="feedback-type-badge {{item.type}}">
              <text class="type-icon">{{item.typeIcon}}</text>
              <text class="type-text">{{item.typeName}}</text>
            </view>
            <!-- 未上报：显示操作按钮 -->
            <view class="action-buttons" wx:if="{{!item.isReported}}">
              <view class="edit-btn" catchtap="editFeedback" data-id="{{item._id}}">
                <text class="edit-icon">✏️</text>
              </view>
              <view class="delete-btn" catchtap="deleteFeedback" data-id="{{item._id}}" data-index="{{index}}">
                <text class="delete-icon">🗑️</text>
              </view>
            </view>
            <!-- 已上报：显示已上报标签 -->
            <view class="reported-badge" wx:else>
              <text class="reported-icon">✓</text>
              <text class="reported-text">已上报</text>
            </view>
          </view>

          <!-- 内容 -->
          <text class="feedback-content">{{item.content}}</text>

          <!-- 截图 -->
          <view class="feedback-images" wx:if="{{item.images && item.images.length > 0}}">
            <image
              class="feedback-image"
              wx:for="{{item.images}}"
              wx:for-item="img"
              wx:for-index="imgIndex"
              wx:key="imgIndex"
              src="{{img}}"
              mode="aspectFill"
              bindtap="previewImage"
              data-url="{{img}}"
              data-urls="{{item.images}}"
            ></image>
          </view>

          <!-- 底部：时间和编号 -->
          <view class="feedback-footer">
            <view class="footer-left">
              <text class="feedback-time">{{item.createTimeText}}</text>
            </view>
            <view class="footer-right">
              <text class="feedback-id">#{{item.shortId}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 加载状态 -->
      <view class="loading-more" wx:if="{{loading && !showSkeleton}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>

      <!-- 没有更多 -->
      <view class="no-more" wx:if="{{!hasMore && feedbackList.length > 0 && !showSkeleton}}">
        <view class="no-more-line"></view>
        <text class="no-more-text">没有更多了</text>
        <view class="no-more-line"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部固定按钮 -->
  <view class="bottom-bar">
    <view class="bottom-content">
      <button class="add-btn" bindtap="goToAddFeedback">
        <view class="add-icon-wrapper">
          <text class="add-icon">+</text>
        </view>
        <text class="add-text">提交反馈</text>
      </button>
    </view>
  </view>
</view>
