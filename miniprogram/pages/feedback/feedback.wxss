/* pages/feedback/feedback.wxss */

.feedback-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8faf9 0%, #eff6ff 100%);
  display: flex;
  flex-direction: column;
}

/* ==================== 导航栏 ==================== */
.nav-bar {
  background: rgba(255, 255, 255, 0.95);
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
  backdrop-filter: blur(20px);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s ease;
}

.nav-back:active {
  background: rgba(0, 0, 0, 0.05);
}

.back-icon {
  font-size: 36rpx;
  color: #1a1d26;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1d26;
}

.nav-placeholder {
  width: 64rpx;
}

/* ==================== 内容滚动区 ==================== */
.content-scroll {
  flex: 1;
  height: calc(100vh - 180rpx);
}

.content-wrapper {
  padding: 32rpx;
  padding-bottom: 160rpx;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}

/* ==================== 反馈列表 ==================== */
.feedback-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feedback-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  animation: fadeInUp 0.4s ease-out forwards;
  opacity: 0;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 顶部：类型 */
.feedback-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.feedback-type-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.feedback-type-badge.bug {
  background: #fef2f2;
  color: #dc2626;
}

.feedback-type-badge.feature {
  background: #eff6ff;
  color: #2563eb;
}

.feedback-type-badge.other {
  background: #f0fdf4;
  color: #16a34a;
}

.type-icon {
  font-size: 24rpx;
}

.type-text {
  font-size: 24rpx;
}

/* 操作按钮容器 */
.action-buttons {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 修改按钮 */
.edit-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #eff6ff;
  transition: all 0.2s ease;
}

.edit-btn:active {
  background: #dbeafe;
  transform: scale(0.9);
}

.edit-icon {
  font-size: 28rpx;
}

/* 删除按钮 */
.delete-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fef2f2;
  transition: all 0.2s ease;
}

.delete-btn:active {
  background: #fee2e2;
  transform: scale(0.9);
}

.delete-icon {
  font-size: 28rpx;
}

/* 已上报标签 */
.reported-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: #f0fdf4;
  color: #16a34a;
}

.reported-icon {
  font-size: 20rpx;
  font-weight: 600;
}

.reported-text {
  font-size: 22rpx;
  font-weight: 500;
}

/* 温馨提示卡片 */
.tip-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  border-radius: 16rpx;
  margin-top: 32rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid #fcd34d;
}

.tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.tip-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tip-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #92400e;
}

.tip-text {
  font-size: 24rpx;
  color: #a16207;
  line-height: 1.6;
}

/* 内容 */
.feedback-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 截图 */
.feedback-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.feedback-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

/* 底部：时间和编号 */
.feedback-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.footer-left {
  display: flex;
  align-items: center;
}

.feedback-time {
  font-size: 24rpx;
  color: #999;
}

.footer-right {
  display: flex;
  align-items: center;
}

.feedback-id {
  font-size: 22rpx;
  color: #ccc;
  font-family: 'SF Mono', monospace;
}

/* ==================== 加载状态 ==================== */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  gap: 12rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #2563eb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 没有更多 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  gap: 20rpx;
}

.no-more-line {
  width: 80rpx;
  height: 1rpx;
  background: #e8e8e8;
}

.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}

/* ==================== 骨架屏 ==================== */
.skeleton-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 骨架屏：脉冲动画 */
.skeleton-pulse {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeletonPulse 1.5s infinite ease-in-out;
}

@keyframes skeletonPulse {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 骨架屏：温馨提示卡片 */
.skeleton-tip-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
}

.skeleton-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.skeleton-tip-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.skeleton-title {
  width: 120rpx;
  height: 28rpx;
  border-radius: 4rpx;
}

.skeleton-text {
  width: 100%;
  height: 24rpx;
  border-radius: 4rpx;
}

/* 骨架屏：反馈列表 */
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeleton-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 骨架屏：顶部 */
.skeleton-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.skeleton-badge {
  width: 120rpx;
  height: 40rpx;
  border-radius: 12rpx;
}

.skeleton-actions {
  display: flex;
  gap: 12rpx;
}

.skeleton-action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

/* 骨架屏：内容 */
.skeleton-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.skeleton-line {
  height: 24rpx;
  border-radius: 4rpx;
}

/* 骨架屏：截图 */
.skeleton-images {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.skeleton-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
}

/* 骨架屏：底部 */
.skeleton-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.skeleton-time {
  width: 120rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

.skeleton-id {
  width: 80rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

/* ==================== 底部固定按钮 ==================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.bottom-content {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.add-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
  transition: all 0.2s ease;
}

.add-btn::after {
  border: none;
}

.add-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.4);
}

.add-icon-wrapper {
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.add-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}
