/* pages/feedback/add/add.wxss */

.add-feedback-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8faf9 0%, #eff6ff 100%);
  display: flex;
  flex-direction: column;
}

/* ==================== 导航栏 ==================== */
.nav-bar {
  background: rgba(255, 255, 255, 0.95);
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
  backdrop-filter: blur(20px);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s ease;
}

.nav-back:active {
  background: rgba(0, 0, 0, 0.05);
}

.back-icon {
  font-size: 36rpx;
  color: #1a1d26;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1d26;
}

.nav-placeholder {
  width: 64rpx;
}

/* ==================== 内容滚动区 ==================== */
.content-scroll {
  flex: 1;
  height: calc(100vh - 180rpx);
}

.form-wrapper {
  padding: 32rpx;
  padding-bottom: 160rpx;
}

/* ==================== 表单区块 ==================== */
.form-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-required {
  font-size: 30rpx;
  color: #dc2626;
  font-weight: 600;
}

.section-optional {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.section-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: -12rpx;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

/* ==================== 问题类型 ==================== */
.type-options {
  display: flex;
  gap: 16rpx;
}

.type-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background: #f8faf9;
  border-radius: 20rpx;
  border: 3rpx solid transparent;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.type-option.active {
  background: #eff6ff;
  border-color: #2563eb;
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.15);
}

.type-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  transition: transform 0.2s ease;
}

.type-icon-wrapper.bug {
  background: #fef2f2;
}

.type-icon-wrapper.feature {
  background: #eff6ff;
}

.type-icon-wrapper.other {
  background: #f0fdf4;
}

.type-option.active .type-icon-wrapper {
  transform: scale(1.1);
}

.type-icon {
  font-size: 36rpx;
}

.type-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.type-desc {
  font-size: 20rpx;
  color: #999;
}

.type-option.active .type-name {
  color: #2563eb;
}

/* ==================== 问题描述 ==================== */
.textarea-wrapper {
  position: relative;
  background: #f8faf9;
  border-radius: 20rpx;
  overflow: hidden;
  transition: all 0.2s ease;
}

.textarea-wrapper:focus-within {
  background: #fff;
  box-shadow: 0 0 0 3rpx rgba(37, 99, 235, 0.2);
}

.content-textarea {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.placeholder-style {
  color: #ccc;
}

.textarea-footer {
  display: flex;
  justify-content: flex-end;
  padding: 0 24rpx 16rpx;
}

.word-count {
  font-size: 22rpx;
  color: #ccc;
  transition: color 0.2s ease;
}

.word-count.warning {
  color: #f59e0b;
}

/* ==================== 截图上传 ==================== */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.delete-btn:active {
  background: rgba(220, 38, 38, 0.8);
  transform: scale(0.9);
}

.delete-icon {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.add-image-btn {
  width: 200rpx;
  height: 200rpx;
  background: #f8faf9;
  border: 3rpx dashed #ddd;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.2s ease;
}

.add-image-btn:active {
  background: #f0f0f0;
  border-color: #2563eb;
}

.add-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  background: rgba(37, 99, 235, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 36rpx;
  color: #2563eb;
  font-weight: 300;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: #999;
}

/* ==================== 联系方式 ==================== */
.input-wrapper {
  display: flex;
  align-items: center;
  background: #f8faf9;
  border-radius: 20rpx;
  padding: 0 24rpx;
  transition: all 0.2s ease;
}

.input-wrapper:focus-within {
  background: #fff;
  box-shadow: 0 0 0 3rpx rgba(37, 99, 235, 0.2);
}

.input-icon {
  margin-right: 16rpx;
}

.icon-text {
  font-size: 32rpx;
}

.contact-input {
  flex: 1;
  height: 96rpx;
  font-size: 28rpx;
  color: #333;
}

/* ==================== 底部提交按钮 ==================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.bottom-content {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
  transition: all 0.2s ease;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active:not(.disabled) {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.4);
}

.submit-btn.disabled {
  background: linear-gradient(135deg, #e8e8e8 0%, #d9d9d9 100%);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.btn-loading {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}
