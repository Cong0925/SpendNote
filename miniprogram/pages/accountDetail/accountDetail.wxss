/**
 * 账户详情页面样式 - 完全重构
 * 从零开始设计，参考账单详情和统计页面
 */

page {
  background: #F5F7FA;
  min-height: 100vh;
}

.page {
  padding-bottom: 180rpx;
}

/* ============ 顶部账户信息卡片 ============ */
.account-hero {
  background: linear-gradient(135deg, #2563EB 0%, #1E40AF 100%);
  padding: 80rpx 32rpx 60rpx;
  position: relative;
  overflow: hidden;
}

.hero-bg-circle {
  position: absolute;
  top: -100rpx;
  right: -60rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.hero-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.account-icon-wrap {
  width: 128rpx;
  height: 128rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.account-icon {
  width: 80rpx;
  height: 80rpx;
}

.account-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.account-type-badge {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
}

.account-type-badge.debt {
  background: rgba(252, 165, 165, 0.3);
  color: #FCA5A5;
}

.account-type-badge.asset {
  background: rgba(134, 239, 172, 0.3);
  color: #86EFAC;
}

/* ============ 金额显示区域 ============ */
.amount-section {
  background: #ffffff;
  margin: -40rpx 32rpx 32rpx;
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 2;
}

.amount-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
  display: block;
}

.amount-input-wrap {
  display: flex;
  align-items: baseline;
}

.amount-symbol {
  font-size: 48rpx;
  font-weight: 700;
  color: #2563EB;
  margin-right: 8rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.amount-input {
  flex: 1;
  font-size: 64rpx;
  font-weight: 700;
  color: #2563EB;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
}

.amount-input::placeholder {
  color: #D1D5DB;
}

/* ============ 表单信息区域 ============ */
.form-section {
  background: #ffffff;
  margin: 0 32rpx 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #111827;
}

.form-input::placeholder {
  color: #9CA3AF;
}

/* ============ 操作按钮区域 ============ */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.btn-save {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #2563EB 0%, #1E40AF 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.35);
}

.btn-save::after {
  border: none;
}

.btn-delete {
  width: 100%;
  height: 96rpx;
  background: #FEE2E2;
  color: #DC2626;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 24rpx;
}

.btn-delete::after {
  border: none;
}
