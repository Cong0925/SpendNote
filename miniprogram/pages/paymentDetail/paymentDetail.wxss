/**
 * 记录详情页面样式 - 与现有页面统一
 */
page {
  background: var(--color-bg);
}

.container {
  min-height: 100vh;
}

/* ============ 加载状态 ============ */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
  gap: 16rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ============ 详情卡片 ============ */
.detail-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 8rpx 32rpx;
  box-shadow: var(--shadow-sm);
  animation: slideUp 0.5s ease-out both;
}

/* ============ 查看模式 ============ */
.detail-view {
  animation: fadeIn 0.4s ease-out both;
}

/* 信息列表 */
.info-list {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

.info-value.amount {
  font-size: 32rpx;
  font-weight: 700;
}

.info-value.amount.expense {
  color: var(--color-expense);
}

.info-value.amount.income {
  color: var(--color-income);
}

.info-value.empty {
  color: var(--color-text-tertiary);
}

.info-divider {
  height: 1rpx;
  background: var(--color-border);
}

/* 图片区域 */
.image-section {
  padding: 24rpx 0;
  border-top: 1rpx solid var(--color-border);
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 150rpx;
  height: 150rpx;
  border-radius: var(--radius-md);
  object-fit: cover;
}

/* ============ 操作按钮 ============ */
.action-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
  padding: 0 16rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.action-btn.delete {
  background: #FEE2E2;
  color: #DC2626;
}

.action-btn.edit {
  background: var(--color-primary);
  color: #ffffff;
}

.action-btn.cancel {
  background: var(--color-bg);
  color: var(--color-text-secondary);
}

.action-btn.save {
  background: linear-gradient(135deg, #10B981 0%, #047857 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

/* ============ 编辑模式 ============ */
.edit-form {
  padding: 0;
  animation: fadeIn 0.4s ease-out both;
}

/* 表单区域 */
.form-section {
  background: var(--color-card);
  margin-bottom: 30rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  animation: slideUp 0.5s ease-out both;
  animation-delay: 0.1s;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text);
  text-align: right;
}

.form-picker {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  font-size: 30rpx;
  color: var(--color-text);
}

.picker-arrow {
  margin-left: 12rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}

/* ============ 图片区域 ============ */
.image-section {
  background: var(--color-card);
  margin-bottom: 30rpx;
  border-radius: var(--radius-xl);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  animation: slideUp 0.5s ease-out both;
  animation-delay: 0.2s;
}

.image-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.image-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 1.5rpx;
}

.image-count {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.image-list {
  display: flex;
  flex-wrap: wrap;
}

.image-item {
  width: 150rpx;
  height: 150rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
  animation: scaleIn 0.3s ease-out both;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  font-size: 28rpx;
  text-align: center;
  line-height: 40rpx;
}

.add-image-btn {
  width: 150rpx;
  height: 150rpx;
  background: var(--color-bg);
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.2s ease;
}

.add-image-btn:active {
  background: var(--color-card);
  border-color: var(--color-primary);
}

.add-icon {
  font-size: 56rpx;
  color: var(--color-text-tertiary);
}

/* ============ 保存按钮 ============ */
.save-btn {
  margin: 48rpx 32rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
  transition: all 0.2s ease;
  animation: slideUp 0.5s ease-out both;
  animation-delay: 0.3s;
}

.save-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* ============ 动画效果 ============ */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(32rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}
