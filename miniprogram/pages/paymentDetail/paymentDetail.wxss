/**
 * 记录详情页面样式 - 与现有页面统一
 */
page {
  background: var(--color-bg);
}

.container {
  min-height: 100vh;
  padding: 24rpx 32rpx;
}

/* ============ 加载状态 ============ */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
  gap: 16rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ============ 详情卡片 ============ */
.detail-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 8rpx 32rpx;
  box-shadow: var(--shadow-sm);
  animation: slideUp 0.5s ease-out both;
}

/* ============ 查看模式 ============ */
.detail-view {
  animation: fadeIn 0.4s ease-out both;
}

/* 类型标识 */
.type-badge {
  display: inline-block;
  padding: 12rpx 32rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.type-badge.receive {
  background: linear-gradient(135deg, #10B981 0%, #047857 100%);
  color: #ffffff;
}

.type-badge.repay {
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  color: #ffffff;
}

/* 金额显示 */
.amount-display {
  text-align: center;
  padding: 48rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  margin-bottom: 16rpx;
}

.amount-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.amount-value {
  display: block;
  font-size: 56rpx;
  color: var(--color-text);
  font-weight: 700;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
  letter-spacing: -2rpx;
}

/* 信息列表 */
.info-list {
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
}

.info-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border);
}

.info-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

.info-value.empty {
  color: var(--color-text-tertiary);
}

/* 图片区域 */
.image-section {
  padding: 24rpx 0;
  border-top: 1rpx solid var(--color-border);
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 150rpx;
  height: 150rpx;
  border-radius: var(--radius-md);
  object-fit: cover;
}

/* ============ 操作按钮 ============ */
.action-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
  padding: 0 16rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.action-btn.delete {
  background: #FEE2E2;
  color: #DC2626;
}

.action-btn.edit {
  background: var(--color-primary);
  color: #ffffff;
}

.action-btn.cancel {
  background: var(--color-bg);
  color: var(--color-text-secondary);
}

.action-btn.save {
  background: linear-gradient(135deg, #10B981 0%, #047857 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

/* ============ 编辑模式 ============ */
.edit-form {
  padding: 16rpx 0;
  animation: fadeIn 0.4s ease-out both;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-card);
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.form-input:focus {
  border-color: var(--color-primary);
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-card);
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.form-picker:focus {
  border-color: var(--color-primary);
}

.picker-arrow {
  color: var(--color-text-light);
  font-size: 24rpx;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-card);
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.form-textarea:focus {
  border-color: var(--color-primary);
}

/* ============ 动画效果 ============ */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(32rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}
