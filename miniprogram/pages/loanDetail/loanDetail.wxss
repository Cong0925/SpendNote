/**
 * 借款详情页面样式 - 与现有页面统一
 */
page {
  background: var(--color-bg);
}

.container {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  padding-bottom: 160rpx;
}

/* ============ 加载状态 ============ */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

/* ============ 信息卡片 ============ */
.info-card {
  background: linear-gradient(135deg, #2563EB 0%, #1E40AF 50%, #1E3A8A 100%);
  border-radius: var(--radius-xl);
  padding: 40rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.3);
  animation: slideUp 0.5s ease-out both;
}

.info-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.info-card::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: 30%;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.party-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.party-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  position: relative;
  z-index: 1;
}

.amount-item {
  flex: 1;
  text-align: center;
}

.amount-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.amount-value {
  display: block;
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 700;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
  letter-spacing: -1rpx;
}

/* ============ 操作记录列表 ============ */
.payment-list {
  background: var(--color-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  animation: slideUp 0.5s ease-out 0.1s both;
}

.list-title {
  padding: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  border-bottom: 1rpx solid var(--color-divider);
}

.list-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.list-loading .loading-spinner {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 0;
  margin-right: 16rpx;
}

.payment-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
  transition: all 0.2s ease;
}

.payment-item:last-child {
  border-bottom: none;
}

.payment-item:active {
  background: var(--color-bg);
  transform: scale(0.98);
}

.payment-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.payment-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.initial-icon {
  background: linear-gradient(135deg, #3B82F6 0%, #1D4ED8 100%);
}

.initial-icon .icon-text {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

.receive-icon {
  background: linear-gradient(135deg, #10B981 0%, #047857 100%);
}

.receive-icon .icon-text {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

.repay-icon {
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
}

.repay-icon .icon-text {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

.icon-text {
  font-size: 24rpx;
  font-weight: 500;
}

.payment-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.payment-type {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.payment-date {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.payment-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.payment-amount {
  font-size: 32rpx;
  color: var(--color-text);
  font-weight: 600;
  margin-right: 16rpx;
  font-family: 'SF Pro Display', -apple-system, sans-serif;
  letter-spacing: -0.5rpx;
}

.payment-arrow {
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* ============ 空状态 ============ */
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

/* ============ 底部按钮 ============ */
.bottom-btn {
  position: fixed;
  bottom: 48rpx;
  left: 32rpx;
  right: 32rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.3);
  transition: all 0.2s ease;
  z-index: 100;
}

.bottom-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ============ 动画效果 ============ */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(32rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
